#!/bin/sh
# pre-commit: the commit gate. Git-native on purpose -- it runs at true commit
# time against the real index, so it covers `git commit -a`, pathspecs, and amend
# content that a command-text check would miss, and it cannot be regex-bypassed or
# wrongly fire on a `grep "git commit"`. Blocks unless a review verdict bound to
# the EXACT to-be-committed tree says PASS. Fails CLOSED. The gate body lives in
# .githooks/gate-core.sh (evidence_gate), shared with commit-msg for event mode.
#
# Commit identity = `git write-tree` (the oid of the staged index = the commit's
# tree). tools/review_verdict.ps1 records the same key. Pure git plumbing, so the
# two sides cannot drift (there is no custom hash scheme to keep in sync).
#
# Guarantee (scoped honestly): on a working copy where this hook is active
# (core.hooksPath -> .githooks; assert with tools/check-gate.ps1) and not bypassed
# with `git commit --no-verify`, no absent / stale / mismatched verdict and no
# unreviewed staged content can reach a commit. It does NOT stop: a deliberately
# forged verdict (same actor can write one), `--no-verify`, or an unconfigured
# clone. Closing those is the program-driven loop (P2), where the verdict comes
# from a reviewer agent call in control flow, not a hand -- plus the CI integrity
# check and the run-start activation assertion. See DESIGN.md "Commit gate".
set -e

root="$(git rev-parse --show-toplevel)"
. "$root/.githooks/gate-core.sh"

# Event mode (#220): while governance/event-mode.json is a valid em1 flag with a
# future expiry, the evidence gate moves to commit-msg -- the hook that can read
# the commit message and scope the bypass to 'hotfix: ' subjects. Every other
# commit still takes the identical gate there, one hook later. An expired or
# invalid flag enables nothing (event_mode_state collapses it to INACTIVE).
# See DESIGN.md "Event mode (#220)".
if [ "$(event_mode_state "$root")" = "ACTIVE" ]; then
  echo "commit-gate: event mode ACTIVE (governance/event-mode.json) -- evidence gate defers to commit-msg; only 'hotfix: ' commits bypass it there." >&2
  exit 0
fi

evidence_gate "$root"

exit 0
