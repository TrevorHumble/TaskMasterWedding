{
  "name": "garden-party-pastels",
  "version": "1.0.0",
  "description": "Wedding scavenger hunt web app for Lilly & Axel.",
  "private": true,
  "type": "commonjs",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node src/app.js",
    "serve": "node scripts/serve-resilient.js",
    "dev": "node src/app.js",
    "seed": "node scripts/seed.js",
    "seed-event": "node scripts/seed-event.js",
    "set-admin": "node scripts/set-admin-password.js",
    "loadtest": "node scripts/loadtest.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "mutation": "stryker run"
  },
  "dependencies": {
    "archiver": "7.0.1",
    "bcryptjs": "3.0.3",
    "better-sqlite3": "12.11.1",
    "cookie-parser": "1.4.7",
    "ejs": "6.0.1",
    "exceljs": "4.4.0",
    "express": "4.21.2",
    "heic-convert": "2.1.0",
    "heic-decode": "2.1.0",
    "jpeg-js": "0.4.4",
    "multer": "2.2.0",
    "qrcode": "1.5.4",
    "sharp": "0.35.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.4",
    "supertest": "^7.0.0",
    "vitest": "^4.1.9"
  }
}
