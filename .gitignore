# .gitignore
# Installed packages
node_modules/

# All live application state (database, uploaded photos, thumbnails, exports, admin hash)
data/

# Backup snapshots (DB copy + photo copies) written by scripts/backup.js.
# Same sensitivity as data/ above -- irreplaceable event data must stay untracked.
backups/

# Ad-hoc/manual demo database + uploads + admin hash (same sensitivity as
# data/ above), and any scripts/seed-story.js DATA_DIR target (#450), e.g.
# data-stories/normal/, data-story-extreme/.
data-demo/
data-stor*/

# Visual-approval-loop DATA_DIR (npm run preview / tools/persist-visual-approval.ps1):
# seeded database + uploads + admin hash, same sensitivity as data/ above.
data-visual/

# Environment secrets
.env

# Local per-box compose override (#571): docker-compose merges this
# automatically if present, so a committed one would silently republish the
# app past the drift guard in tests/compose-port-binding.test.js. It is a
# per-box escape hatch, never checked in.
docker-compose.override.yml

# Local enforcement state, per working copy -- never commit:
#  - .review_state/ : commit-gate verdicts (a committed or forged verdict defeats the gate)
#  - .run_state/    : timed-run + loop-gate state (machine-local run.json / STOP sentinel)
.review_state/
.run_state/

# OS / editor noise
Thumbs.db
.DS_Store
*.log
npm-debug.log*

# Generated symlink mirror of .agents/skills/ (core.symlinks=false would commit these as broken text files)
.claude/skills/

# Test coverage output
coverage/

# Mutation-testing output (Stryker, #199): scratch dir + generated report
.stryker-tmp/
reports/
