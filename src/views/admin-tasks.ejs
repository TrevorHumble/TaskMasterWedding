<!-- src/views/admin-tasks.ejs -->
<%- include('partials/head') %>
<%- include('partials/header') %>

  <h1 class="display-title">Tasks</h1>

  <% if (msg) { %>
    <p class="flash"><%= msg %></p>
  <% } %>

  <p class="page-actions">
    <a href="/admin">&larr; Dashboard</a>
  </p>

  <form action="/admin/tasks" method="post" class="stacked-form">
    <h2>Add a task</h2>
    <label>
      Title
      <input type="text" name="title" required placeholder="e.g. Photo with the couple" />
    </label>
    <label>
      Description (optional)
      <textarea name="description" rows="2" placeholder="What should the guest photograph?"></textarea>
    </label>
    <label class="checkbox-label">
      <input type="checkbox" name="add_to_top" value="1" />
      Add to top of the list
    </label>
    <button type="submit" class="btn btn-primary">Add task</button>
  </form>

  <div class="task-admin-list">
    <% tasks.forEach(function (t) { %>
      <article class="task-admin-card <%= t.is_active ? '' : 'row-inactive' %>" id="task-<%= t.id %>">
        <form action="/admin/tasks/<%= t.id %>/edit" method="post"
              id="task-edit-<%= t.id %>" class="task-edit-form">
          <label>
            Title
            <input type="text" name="title" value="<%= t.title %>" required />
          </label>
          <label>
            Description
            <textarea name="description" rows="3"><%= t.description %></textarea>
          </label>
        </form>

        <div class="task-badge-row">
          <div class="task-badge-row-current">
            <img class="badge-art" src="<%= t.badge.art_path %>" alt="<%= t.badge.name %>" />
            <span class="badge-name"><%= t.badge.name %></span>
          </div>
          <% if (t.badge.isDefault) { %>
            <form action="/admin/tasks/<%= t.id %>/badge" method="post" enctype="multipart/form-data"
                  class="task-badge-upload-form">
              <input type="text" name="name" placeholder="Badge name (e.g. Golden Move)" />
              <%- include('partials/upload-field', { id: 'badge-art-' + t.id, name: 'badge_art', accept: 'image/*', label: 'Upload badge art…' }) %>
              <button type="submit" class="btn btn-sm btn-secondary">Upload badge</button>
            </form>
          <% } %>
        </div>

        <div class="task-card-actions">
          <button type="submit" form="task-edit-<%= t.id %>" class="btn btn-sm btn-secondary">Save</button>
          <form action="/admin/tasks/<%= t.id %>/active" method="post">
            <button type="submit" class="btn btn-sm btn-ghost">
              <%= t.is_active ? 'Active (hide)' : 'Hidden (show)' %>
            </button>
          </form>
          <form action="/admin/tasks/<%= t.id %>/delete" method="post"
                data-confirm="Delete the task &quot;<%= t.title %>&quot; and ALL its photo submissions? This cannot be undone.">
            <button type="submit" class="btn btn-sm btn-danger">Delete</button>
          </form>
          <span class="task-meta muted">
            <a href="/gallery?task=<%= t.id %>"><%= t.submissions %> photos</a>
          </span>
        </div>

        <div class="task-move-row">
          <form action="/admin/tasks/reorder" method="post">
            <input type="hidden" name="id" value="<%= t.id %>" />
            <input type="hidden" name="direction" value="top" />
            <button type="submit" class="btn btn-sm btn-ghost" <%= t.isFirst ? 'disabled' : '' %>>Move to top</button>
          </form>
          <form action="/admin/tasks/reorder" method="post">
            <input type="hidden" name="id" value="<%= t.id %>" />
            <input type="hidden" name="direction" value="up" />
            <button type="submit" class="btn btn-sm btn-ghost" <%= t.isFirst ? 'disabled' : '' %> aria-label="Move up">▲</button>
          </form>
          <form action="/admin/tasks/reorder" method="post">
            <input type="hidden" name="id" value="<%= t.id %>" />
            <input type="hidden" name="direction" value="down" />
            <button type="submit" class="btn btn-sm btn-ghost" <%= t.isLast ? 'disabled' : '' %> aria-label="Move down">▼</button>
          </form>
        </div>
      </article>
    <% }); %>
    <% if (tasks.length === 0) { %>
      <p class="muted">No tasks yet. Add one above.</p>
    <% } %>
  </div>

<script src="/js/admin.js" defer></script>
<%- include('partials/footer') %>
