<!-- src/views/admin-tasks.ejs -->
<%- include('partials/head') %>
<%- include('partials/header') %>

  <h1 class="display-title">Tasks</h1>

  <% if (msg) { %>
    <p class="flash"><%= msg %></p>
  <% } %>

  <p class="page-actions">
    <a href="/admin">&larr; Dashboard</a>
  </p>

  <div class="admin-tasks-head">
    <p class="admin-tasks-count muted"><%= tasks.length %> task<%= tasks.length === 1 ? '' : 's' %></p>
    <button type="button" class="btn btn-primary btn-sm admin-task-new" data-open-create>New task</button>
  </div>

  <ul class="admin-task-list" id="admin-task-list">
    <% tasks.forEach(function (t) { %>
      <li class="admin-task-card <%= t.is_active ? '' : 'is-hidden' %>"
          id="task-<%= t.id %>"
          data-task-id="<%= t.id %>"
          data-title="<%= t.title %>"
          data-description="<%= t.description %>"
          data-worth="<%= t.worth %>"
          data-mode="<%= t.special_mode %>"
          data-special-date="<%= t.special_date || '' %>"
          data-special-bonus="<%= t.special_bonus || '' %>"
          data-badge-name="<%= t.badge.isDefault ? '' : t.badge.name %>"
          data-badge-art="<%= t.badge.isDefault ? '' : t.badge.art_path %>"
          data-badge-default="<%= t.badge.isDefault ? '1' : '0' %>">
        <span class="admin-task-drag" aria-hidden="true" title="Drag to reorder">
          <svg viewBox="0 0 16 16" width="16" height="16" focusable="false">
            <circle cx="5" cy="3" r="1.4" /><circle cx="11" cy="3" r="1.4" />
            <circle cx="5" cy="8" r="1.4" /><circle cx="11" cy="8" r="1.4" />
            <circle cx="5" cy="13" r="1.4" /><circle cx="11" cy="13" r="1.4" />
          </svg>
        </span>
        <button type="button" class="admin-task-open" data-edit-task="<%= t.id %>">
          <span class="admin-task-badge-col">
            <% if (t.badge.isDefault) { %>
              <span class="badge-medallion badge-medallion-empty" aria-hidden="true"></span>
              <span class="admin-task-badge-name muted">No badge</span>
            <% } else { %>
              <%- include('partials/badge-art', { badge: t.badge }) %>
              <span class="admin-task-badge-name"><%= t.badge.name %></span>
            <% } %>
          </span>
          <span class="admin-task-body">
            <span class="task-title-text"><%= t.title %></span>
            <% if (t.description) { %>
              <span class="admin-task-desc"><%= t.description %></span>
            <% } else { %>
              <span class="admin-task-desc muted">No description</span>
            <% } %>
          </span>
          <span class="task-points">+<%= t.worth %> pt<%= t.worth === 1 ? '' : 's' %></span>
        </button>
        <div class="admin-chip-strip">
          <% if (!t.is_active) { %>
            <span class="admin-chip admin-chip-hidden">Hidden</span>
          <% } %>
          <% if (t.oneday) { %>
            <span class="admin-chip admin-chip-oneday"><%= t.dayLabel %> only</span>
          <% } %>
          <a class="admin-task-photos" href="/admin/photos?view=task&amp;task=<%= t.id %>"><%= t.submissions %> photo<%= t.submissions === 1 ? '' : 's' %></a>
        </div>
        <%# A real, server-rendered form per task (issue #59's data-confirm
            convention — src/public/js/admin.js's delegated submit listener,
            same as the guest/photo/comment delete forms) rather than a
            hand-rolled window.confirm in admin-tasks.js. Hidden — the visible
            Delete control lives in the edit popup; its click handler
            (admin-tasks.js) finds THIS form by data-task-id and calls
            requestSubmit(), which fires a real 'submit' event admin.js's
            listener can intercept (form.submit() would NOT). %>
        <form action="/admin/tasks/<%= t.id %>/delete" method="post"
              class="admin-task-delete-form" data-task-id="<%= t.id %>"
              data-confirm="Delete <%= t.title %> and all its photos (photos are removed from disk)? This cannot be undone."
              hidden></form>
      </li>
    <% }); %>
    <% if (tasks.length === 0) { %>
      <li class="admin-task-empty muted">No tasks yet. Tap &ldquo;New task&rdquo; to add the first one.</li>
    <% } %>
  </ul>

  <%- include('partials/task-edit-dialog') %>
  <%- include('partials/task-create-dialog') %>
  <%- include('partials/badge-picker', { badgeIcons: badgeIcons }) %>

<script src="/js/admin.js" defer></script>
<script src="/js/badge-picker.js" defer></script>
<script src="/js/admin-tasks.js" defer></script>
<%- include('partials/footer') %>
