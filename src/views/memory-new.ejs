<!-- src/views/memory-new.ejs -->
<%- include('partials/head', { title: title }) %>
<%- include('partials/header') %>

  <p class="back-link"><a href="/gallery">&#8592; Gallery</a></p>
  <h1 class="page-title">Share a memory</h1>

  <p class="muted">
    Got photos from tonight that don't match a task? Add them straight to the
    shared gallery. Your first memory each day is +1 point, but share as many
    as you'd like.
  </p>

  <% if (typeof error !== 'undefined' && error) { %>
    <p class="form-error" role="alert"><%= error %></p>
  <% } %>

  <section class="upload-section">
    <form action="/memories"
          method="POST"
          enctype="multipart/form-data">

      <div class="form-row">
        <%- include('partials/upload-field', {
          id: 'photos',
          name: 'photos',
          accept: 'image/jpeg,image/png,image/webp',
          required: true,
          multiple: true,
          label: 'Choose photos…'
        }) %>
      </div>

      <div class="form-row" id="caption-field">
        <label for="caption" class="form-label">Caption (optional)</label>
        <input type="text"
               id="caption"
               name="caption"
               maxlength="500"
               placeholder="Say something about these photos"
               class="text-input" />
      </div>
      <p class="form-help caption-batch-note" id="caption-batch-note" hidden>
        To add a caption, please choose one photo at a time.
      </p>

      <button type="submit" class="btn btn-block">Share</button>
    </form>
  </section>

  <!-- Direct include of the filename-label script (see task.ejs's note). -->
  <script src="/js/upload-filename.js" defer></script>
  <!-- Memory-scoped caption toggle (issue #364 AC7/AC8) — not part of the
       shared upload-filename control since no other upload caller has a
       caption box to toggle. -->
  <script src="/js/memory-caption.js" defer></script>

<%- include('partials/footer') %>
