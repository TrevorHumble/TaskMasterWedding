<!-- src/views/guest-home.ejs -->
<%- include('partials/head', { title: title }) %>
<%- include('partials/header') %>

  <section class="profile-card">
    <div class="profile-avatar-wrap">
      <% if (guest.avatar_path) { %>
        <img src="/uploads/<%= guest.avatar_path %>" alt="Your avatar" class="avatar-img" />
      <% } else { %>
        <div class="avatar-circle">
          <%= initials(guest.name) || '?' %>
        </div>
      <% } %>
    </div>
    <div class="profile-info">
      <h1 class="profile-name-home"><%= guest.name && guest.name.length ? guest.name : 'Welcome!' %></h1>
      <p class="profile-meta-row">
        <span class="profile-points-inline"><strong><%= points %></strong> point<%= points === 1 ? '' : 's' %></span>
        <span class="profile-meta-sep" aria-hidden="true">·</span>
        <a href="/me/edit">Edit profile</a>
      </p>
    </div>
  </section>

  <section class="progress-section">
    <div class="progress" role="progressbar"
         aria-valuenow="<%= progressPercent %>" aria-valuemin="0" aria-valuemax="100">
      <div class="progress-fill" style="width: <%= progressPercent %>%;"></div>
    </div>
    <p class="progress-caption"><%= completedTasks %> of <%= totalTasks %> task<%= totalTasks === 1 ? '' : 's' %> complete</p>
  </section>

  <section class="badges-section">
    <h2 class="section-title">My Badges</h2>
    <% if (badges.length === 0) { %>
      <p class="muted">No badges yet — complete tasks to earn your first.</p>
    <% } else { %>
      <ul class="badge-grid">
        <% badges.forEach(function (b) { %>
          <li class="badge-item">
            <a href="/badge/<%= b.code %>">
              <%- include('partials/badge-art', { badge: b, alt: b.name + ' badge', width: 48, height: 48 }) %>
              <span class="badge-text">
                <span class="badge-name">
                  <%= b.name %><% if (b.pointsLabel) { %> <span class="badge-points"><%= b.pointsLabel %></span><% } %>
                </span>
                <% if (b.description) { %>
                  <span class="badge-desc"><%= b.description %></span>
                <% } %>
              </span>
            </a>
          </li>
        <% }); %>
      </ul>
    <% } %>
  </section>

  <section class="my-photos-section">
    <h2 class="section-title">My Photos</h2>
    <% if (submissions.length === 0) { %>
      <p class="muted">No photos yet. <a href="/tasks">See the tasks</a></p>
    <% } else { %>
      <ul class="photo-grid">
        <% submissions.forEach(function (s) { %>
          <% var captionText = s.task_id ? s.task_title : s.caption; %>
          <% var photoName = captionText || 'a shared memory'; %>
          <li class="photo-item">
            <%# Every thumbnail opens the photo detail view at /p/:id (issue
                #613), mirroring the anchor-around-thumbnail pattern already
                shipped on public-profile.ejs (:92-105). A memory (issue #247,
                s.task_id IS NULL) has no task to link to — the accessible
                name and caption fall back to the memory's own caption, or
                "a shared memory" if there's no caption either (AC4/AC8). %>
            <a href="/p/<%= s.id %>" aria-label="View photo for <%= photoName %>">
              <img src="/thumbs/<%= s.thumb_path %>" alt="<%= photoName %>" class="photo-thumb" />
            </a>
            <span class="photo-caption"><%= captionText %></span>
          </li>
        <% }); %>
      </ul>
    <% } %>
  </section>

  <%# Profile bottom menu (issue #252, revised 2026-07-09 visual review) —
      replaces the old stacked button hierarchy with a single bordered list:
      icon + label + chevron, "Report a bug" always last and muted. The
      original five rows opened with View all tasks / Shared gallery /
      Leaderboard, which duplicated the masthead nav directly above this
      menu; those three are cut and Share a memory is pinned first. Row
      order is AC4's exact literal order. %>
  <ul class="menu-list">
    <li class="menu-row">
      <a class="menu-link" href="/memories/new">
        <span class="menu-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="20" height="20" style="fill:currentColor">
            <path d="M3 9a2 2 0 0 1 2-2h2.5l1-1.5h7l1 1.5H19a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V9z M11 10H13V13H16V15H13V18H11V15H8V13H11V10Z"/>
          </svg>
        </span>
        <span class="menu-label">Share a memory</span>
      </a>
    </li>
    <li class="menu-row">
      <a class="menu-link" href="/how-to-play">
        <span class="menu-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="20" height="20" style="fill:currentColor">
            <path d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20zm1 15h-2v-2h2v2zm1.6-6.1c-.7.7-1.1 1.15-1.1 2.1h-2c0-1.55.7-2.2 1.4-2.9.55-.55.9-.9.9-1.6 0-.85-.65-1.5-1.8-1.5-.85 0-1.45.35-1.8.95l-1.65-1c.65-1.1 1.8-1.85 3.45-1.85 2.05 0 3.6 1.25 3.6 3.15 0 1.1-.5 1.75-1 2.65z"/>
          </svg>
        </span>
        <span class="menu-label">How to play</span>
      </a>
    </li>
    <%# Log out (issue #529) — a POST form styled as a menu row, not a GET link,
        so a crawler/prefetcher can never end a guest's session. Sits between
        How to play and Report a bug per owner's 2026-07-18 placement call. %>
    <li class="menu-row">
      <form method="post" action="/logout" class="menu-logout-form">
        <button type="submit" class="menu-link menu-link-button">
          <span class="menu-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="20" height="20" style="fill:currentColor">
              <path d="M10 3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h5v-2H5V5h5V3zm7.5 5.5-1.4 1.4L18.2 12H9v2h9.2l-2.1 2.1 1.4 1.4L22 13l-4.5-4.5z"/>
            </svg>
          </span>
          <span class="menu-label">Log out</span>
        </button>
      </form>
    </li>
    <li class="menu-row">
      <a class="menu-link menu-link-muted" href="/bug-report">
        <span class="menu-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="20" height="20" style="fill:currentColor">
            <path d="M14 5.5l1.6-1.6-1.1-1.1L12.7 4.6a4.9 4.9 0 0 0-1.4 0L9.5 2.8 8.4 3.9 10 5.5A5 5 0 0 0 8.1 8H5v2h2.06A5.9 5.9 0 0 0 7 11v1H5v2h2v1a5.9 5.9 0 0 0 .06 1H5v2h3.1A5 5 0 0 0 12 20a5 5 0 0 0 3.9-2H19v-2h-2.06c.04-.33.06-.66.06-1v-1h2v-2h-2v-1c0-.34-.02-.67-.06-1H19V8h-3.1A5 5 0 0 0 14 5.5zM14 16h-4v-2h4v2zm0-4h-4v-2h4v2z"/>
          </svg>
        </span>
        <span class="menu-label">Report a bug</span>
      </a>
    </li>
  </ul>

<%- include('partials/footer') %>
