<!-- src/views/admin-guests.ejs -->
<%- include('partials/head') %>
<%- include('partials/header') %>

  <h1 class="display-title">Guests</h1>

  <% if (msg) { %>
    <p class="flash"><%= msg %></p>
  <% } %>

  <p class="page-actions">
    <a href="/admin">&larr; Dashboard</a>
    <a class="btn btn-secondary btn-sm" href="/admin/qrsheet">Print QR place-cards</a>
  </p>

  <input type="search" id="guest-search" class="form-input guest-search"
         placeholder="Search guests by name&hellip;" autocomplete="off"
         aria-label="Search guests by name" />

  <h2 class="guest-list-heading">Guests <span class="muted">(<%= guests.length %>)</span></h2>

  <div class="guest-list">
    <% guests.forEach(function (g) { %>
      <article class="guest-card" id="guest-<%= g.id %>" data-guest-name="<%= g.name %>">
        <form action="/admin/guests/<%= g.id %>/edit" method="post" class="guest-name-form">
          <input type="text" name="name" value="<%= g.name %>" placeholder="(no name)"
                 aria-label="Guest name" />
          <label class="guest-pin-label">
            <input type="checkbox" name="pinned" value="1" <%= g.pinned ? 'checked' : '' %> />
            Pin first in the gallery
          </label>
          <button type="submit" class="btn btn-sm btn-secondary">Save</button>
        </form>

        <p class="guest-meta"><%= g.points %> pts · <%= g.completed %>/<%= totalTasks %> tasks</p>

        <p class="guest-identity-meta">
          Contact: <%= g.contact ? g.contact : 'none on file' %> ·
          Re-entry code: <%= g.pin ? g.pin : 'none set' %>
        </p>

        <form action="/admin/guests/<%= g.id %>/identity" method="post" class="guest-identity-form">
          <label class="guest-identity-label">
            Contact
            <input type="text" name="contact" value="<%= g.contact %>"
                   placeholder="email or phone" aria-label="Guest contact (email or phone)" />
          </label>
          <label class="guest-identity-label">
            Re-entry code
            <input type="text" name="pin" value="<%= g.pin %>"
                   pattern="\d{4}" maxlength="4" inputmode="numeric"
                   placeholder="4 digits" aria-label="Guest re-entry PIN" />
          </label>
          <button type="submit" class="btn btn-sm btn-secondary">Update</button>
        </form>

        <div class="guest-link-row">
          <input type="text" readonly value="<%= g.link %>" onclick="this.select();"
                 aria-label="Private sign-in link" />
          <button type="button" class="btn btn-sm btn-secondary copy-link"
                  data-link="<%= g.link %>">Copy</button>
          <span class="copy-confirm" hidden>Copied!</span>
        </div>

        <div class="guest-card-actions">
          <form action="/admin/guests/<%= g.id %>/points" method="post" class="guest-points-form">
            <label class="guest-points-label">Bonus
              <input type="number" name="delta" value="1" aria-label="Bonus points to apply" />
            </label>
            <button type="submit" class="btn btn-sm btn-secondary">Apply</button>
            <span class="muted">cur: <%= g.bonus_points %></span>
          </form>

          <% if (specialBadges.length) { %>
            <form action="/admin/guests/<%= g.id %>/badge" method="post" class="badge-award-form">
              <select name="code" class="badge-select" aria-label="Badge to award or remove">
                <% specialBadges.forEach(function (b) { %>
                  <% var held = g.heldCodes.indexOf(b.code) !== -1; %>
                  <option value="<%= b.code %>">
                    <%= held ? '★ ' + b.name + ' — remove' : b.name %>
                  </option>
                <% }); %>
              </select>
              <input type="hidden" name="action" value="toggle" />
              <button type="submit" class="btn btn-sm btn-secondary">Go</button>
            </form>
          <% } %>

          <form action="/admin/guests/<%= g.id %>/delete" method="post" class="guest-delete-form"
                data-confirm="Delete <%= g.name || ('guest #' + g.id) %> and PERMANENTLY remove all their photos (files deleted from disk) and badges? This cannot be undone.">
            <button type="submit" class="btn btn-sm btn-danger">Delete</button>
          </form>
        </div>
      </article>
    <% }); %>
    <% if (guests.length === 0) { %>
      <p class="muted">No guests yet. Add one below.</p>
    <% } %>
  </div>

  <p class="muted">
    Each guest has a private sign-in link. Give it to them by printing the QR
    sheet, or copy a link above.
  </p>

  <details class="setup-details">
    <summary>Add one guest</summary>
    <form action="/admin/guests" method="post" class="inline-form">
      <label>
        Name (optional)
        <input type="text" name="name" placeholder="e.g. Aunt Marigold" />
      </label>
      <button type="submit" class="btn btn-primary">Add guest</button>
    </form>
  </details>

  <details class="setup-details">
    <summary>Bulk create</summary>
    <form action="/admin/guests/bulk" method="post" class="inline-form"
          data-confirm="Create this many new blank guests?">
      <label>
        How many?
        <input type="number" name="count" min="1" max="500" value="10" />
      </label>
      <button type="submit" class="btn btn-primary">Create blanks</button>
    </form>
  </details>

  <details class="setup-details">
    <summary>Create a custom badge</summary>
    <form action="/admin/badges" method="post" class="inline-form">
      <label>
        Name
        <input type="text" name="name" required placeholder="e.g. Best Dressed" />
      </label>
      <label>
        Art (an emoji works great)
        <input type="text" name="art_path" required placeholder="e.g. 🎩 or /badges/best-dressed.svg" />
      </label>
      <label>
        Description (optional)
        <input type="text" name="description" placeholder="Why this badge exists" />
      </label>
      <button type="submit" class="btn btn-primary">Create badge</button>
    </form>
  </details>

<script src="/js/filter.js" defer></script>
<script src="/js/admin.js" defer></script>
<%- include('partials/footer') %>
