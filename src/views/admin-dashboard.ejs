<!-- src/views/admin-dashboard.ejs -->
<%- include('partials/head') %>
<%- include('partials/header') %>

  <h1 class="display-title">Today</h1>

  <% if (msg) { %>
    <p class="flash"><%= msg %></p>
  <% } %>

  <section class="stat-grid stat-grid-3">
    <a class="stat" href="/admin/guests">
      <span class="stat-num"><%= counts.guests %></span>
      <span class="stat-label">Guests</span>
    </a>
    <a class="stat" href="/admin/tasks">
      <span class="stat-num"><%= counts.activeTasks %></span>
      <span class="stat-label">Live tasks</span>
    </a>
    <a class="stat" href="/admin/bugs">
      <span class="stat-num<%= openBugs > 0 ? ' stat-num-danger' : '' %>"><%= openBugs %></span>
      <span class="stat-label">Open bugs</span>
    </a>
    <%# NOTIFICATION TREATMENT (the open design question, #646): one long row
        across the bottom of the stat grid, not a separate strip above it. %>
    <a class="stat-nudge<%= urgentCount > 0 ? ' stat-nudge-urgent' : '' %>" href="#checklist">
      <%= openCount %> things need you<% if (urgentCount > 0) { %>, <%= urgentCount %> urgent<% } %>
    </a>
  </section>

  <p class="pulse-line">
    <% if (lastPhoto) { %>
      Last photo <%= lastPhoto.rel %> &middot; <%= lastPhoto.name %>
    <% } else { %>
      No photos yet. The place-cards are ready when you are.
    <% } %>
  </p>

  <h2 class="section-heading" id="checklist">Your checklist</h2>

  <ul class="check-list">
    <% rows.forEach(function (row) { %>
      <li class="check-row check-<%= row.state %><%= row.urgent ? ' check-urgent' : '' %>">
        <%
          // Three row shapes (issue #646): a plain link (href present), a
          // manual checkbox (kind === 'manual' — a form-post button styled
          // identically to the link, since a manual row is the only one that
          // WRITES rather than navigates), or static text (a tip or a done
          // row carrying neither).
        %>
        <% if (row.kind === 'manual') { %>
          <form class="check-manual-form" method="post" action="/admin/checklist/<%= row.id %>/toggle">
            <%- include('partials/csrf-field') %>
            <input type="hidden" name="checked" value="<%= row.checked ? '1' : '0' %>">
            <%# The visible box glyph that signals checked/unchecked sits inside
                aria-hidden="true" below, so a screen reader hears nothing that
                distinguishes the two states from the visible text alone — put
                the state in the accessible name instead (issue #646 review
                fix). No rendered pixel changes: aria-label never paints. %>
            <button type="submit" class="check-link" aria-label="<%= row.label %><%= row.sub ? ', ' + row.sub : '' %>, <%= row.checked ? 'checked' : 'not checked' %>">
        <% } else if (row.href) { %>
          <a class="check-link" href="<%= row.href %>">
        <% } else { %>
          <span class="check-link check-link-static">
        <% } %>
          <span class="check-box" aria-hidden="true">
            <% if (row.state === 'tip') { %>
              <svg viewBox="0 0 24 24" width="20" height="20" style="fill:currentColor">
                <path d="M12 3a6 6 0 0 0-3.5 10.9c.5.4.8 1 .8 1.6v.5h5.4v-.5c0-.6.3-1.2.8-1.6A6 6 0 0 0 12 3zM9.3 18h5.4v1.2H9.3V18zm.9 2.6h3.6c-.3.7-1 1.2-1.8 1.2s-1.5-.5-1.8-1.2z"/>
              </svg>
            <% } %>
            <% if (row.state === 'done') { %>
              <svg viewBox="0 0 24 24" width="20" height="20" style="fill:currentColor">
                <path d="M9.6 16.8 5.4 12.6 6.8 11.2l2.8 2.8 7.6-7.6 1.4 1.4z"/>
              </svg>
            <% } %>
          </span>
          <span class="check-body">
            <span class="check-label"><%= row.label %></span>
            <% if (row.sub) { %><span class="check-sub"><%= row.sub %></span><% } %>
          </span>
        <% if (row.kind === 'manual') { %>
            </button>
          </form>
        <% } else if (row.href) { %></a><% } else { %></span><% } %>
      </li>
    <% }); %>
  </ul>

  <h2 class="section-heading">Setup</h2>

  <ul class="menu-list">
    <li class="menu-row">
      <a class="menu-link" href="/admin/config">
        <span class="menu-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="20" height="20" style="fill:currentColor">
            <path d="M12 8a4 4 0 1 0 0 8 4 4 0 0 0 0-8zm0 2a2 2 0 1 1 0 4 2 2 0 0 1 0-4zm7.4 2 1.8 1.4-1.7 3-2.2-.6a5.7 5.7 0 0 1-1.3.8l-.5 2.2H12.7l-.5-2.2a5.7 5.7 0 0 1-1.3-.8l-2.2.6-1.7-3L8.8 14a5.9 5.9 0 0 1 0-1.5L7 11.1l1.7-3 2.2.6c.4-.3.8-.6 1.3-.8l.5-2.2h3.4l.5 2.2c.5.2.9.5 1.3.8l2.2-.6 1.7 3-1.8 1.4c.05.5.05 1 0 1.5z"/>
          </svg>
        </span>
        <span class="menu-label">Configuration: timezone &amp; dates</span>
      </a>
    </li>
    <li class="menu-row">
      <a class="menu-link" href="/admin/poster">
        <span class="menu-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="20" height="20" style="fill:currentColor">
            <path d="M7 3h10v4H7V3zM6 8h12a3 3 0 0 1 3 3v5h-4v4H7v-4H3v-5a3 3 0 0 1 3-3zm3 8v3h6v-5H9v2zm9-5.5a1 1 0 1 0 0 2 1 1 0 0 0 0-2z"/>
          </svg>
        </span>
        <span class="menu-label">Invite guests</span>
      </a>
    </li>
    <li class="menu-row">
      <a class="menu-link" href="/admin/export">
        <span class="menu-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="20" height="20" style="fill:currentColor">
            <path d="M11 3h2v9.2l3.1-3.1 1.4 1.4L12 16l-5.5-5.5 1.4-1.4L11 12.2V3zM5 18h14v2H5v-2z"/>
          </svg>
        </span>
        <span class="menu-label">Download the keepsake export</span>
      </a>
    </li>
    <li class="menu-row">
      <button type="button" class="menu-link menu-link-button" data-open-slideshow aria-haspopup="dialog">
        <span class="menu-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="20" height="20" style="fill:currentColor">
            <path d="M4 4h16a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2zm6 3.5v6l5-3-5-3zM8 20h8v1.5H8V20z"/>
          </svg>
        </span>
        <span class="menu-label">Play slideshow</span>
      </button>
    </li>
  </ul>

  <dialog class="slideshow-dialog" id="slideshow-dialog" aria-labelledby="slideshow-dialog-title">
    <form class="slideshow-dialog-form" method="get" action="/slideshow" target="_blank">
      <div class="slideshow-dialog-header">
        <h2 class="slideshow-dialog-title" id="slideshow-dialog-title">Play slideshow</h2>
        <button type="button" class="slideshow-dialog-close" data-close-slideshow aria-label="Close">&times;</button>
      </div>
      <div class="slideshow-dialog-body">
        <div class="sl-modes">
          <label class="sl-mode">
            <input type="radio" name="mode" value="auto" checked>
            <span class="sl-mode-title">Auto</span>
          </label>
          <label class="sl-mode">
            <input type="radio" name="mode" value="directed">
            <span class="sl-mode-title">Directed</span>
          </label>
        </div>
      </div>
      <div class="slideshow-dialog-foot">
        <button type="submit" class="btn btn-primary">Start slideshow</button>
      </div>
    </form>
  </dialog>

  <script src="/js/slideshow-launch.js" defer></script>

<%- include('partials/footer') %>
