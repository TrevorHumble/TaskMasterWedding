<%# src/views/partials/head.ejs %>
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
  <meta name="theme-color" content="#467058">
  <meta name="robots" content="noindex, nofollow">
  <%# Issue #284: the CSRF token every write-fetch in src/public/js reads via
      window.csrfHeader() (src/public/js/csrf.js). Same token
      partials/csrf-field.ejs renders as a hidden form field; this tag is the
      one place client JS (which has no form to read a hidden input from) gets
      it. Falls back to an empty string on a render this local was never
      passed to (there is none today — csrfMiddleware runs on every request —
      but this view is included by every page, so it must not throw on a
      hypothetical future one that skips the middleware). %>
  <meta name="csrf-token" content="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
  <title><%= (typeof title !== 'undefined' && title) ? title : 'Wedding Master' %></title>
  <%# Every font (display, body, and the masthead script face) is self-hosted
      under src/public/fonts/ — no external font-CDN request at the venue
      (issue #252 AC3). @font-face rules live in theme.css. %>
  <link rel="stylesheet" href="/css/theme.css">
</head>
<body>
