</head>
<body>
  <div class="card">
    <svg class="heart" viewBox="0 0 24 24" width="36" height="36" aria-hidden="true"><path d="M12 21s-8.5-5.3-8.5-11.2A4.8 4.8 0 0 1 12 6.6a4.8 4.8 0 0 1 8.5 3.2C20.5 15.7 12 21 12 21z"/></svg>
