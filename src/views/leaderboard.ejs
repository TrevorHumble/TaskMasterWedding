<!-- src/views/leaderboard.ejs -->
<%- include('partials/head') %>
<%- include('partials/header') %>

  <h1 class="page-title center">Leaderboard</h1>
  <div class="heart-divider" style="color:var(--color-primary);"><%- include('partials/heart', { size: 20 }) %></div>

  <% if (rows.length === 0) { %>
    <p class="muted center">No guests yet.</p>
  <% } else { %>
    <%
      // All podium/tie/rank decisions are precomputed in the route (podiumGroups
      // with shownMembers / namedMembers / namesTail / barLabel / subLine,
      // showPodium, each row's rankLabel) and the badge cap comes from config
      // (badgeCap). This view only renders that structure — it does NOT
      // re-bucket rows or re-derive tie membership.
    %>

    <% if (!showPodium) { %>
      <p class="podium-low-spread center muted">It's a clean sweep — everyone's tied.</p>
    <% } else { %>
      <div class="podium">
        <% podiumGroups.forEach(function (g) { %>
          <div class="podium-slot rank-<%= g.rank %>">
            <% if (g.isTie) { %>
              <div class="podium-stack">
                <% g.shownMembers.forEach(function (r) { %>
                  <a class="podium-stack-avatar" href="/u/<%= r.id %>" title="<%= r.name || 'Guest' %>">
                    <% if (r.avatar_path) { %>
                      <img src="/uploads/<%= r.avatar_path %>" alt="<%= r.name || 'Guest' %>" width="44" height="44" />
                    <% } else { %>
                      <span class="podium-stack-initials"><%= initials(r.name) || '?' %></span>
                    <% } %>
                  </a>
                <% }); %>
                <% if (g.extraCount > 0) { %>
                  <span class="podium-stack-more">+<%= g.extraCount %></span>
                <% } %>
              </div>
              <%
                // "Liam, Priya and Noah" / "Liam, Priya and 3 more" — each
                // named guest is a profile link; separators follow natural
                // joining (", " between, " and " before the last name). One
                // template line so no stray whitespace lands before a comma.
              %>
              <div class="podium-name podium-names"><% g.namedMembers.forEach(function (r, i) { %><%= i === 0 ? '' : (i === g.namedMembers.length - 1 && !g.namesTail ? ' and ' : ', ') %><a href="/u/<%= r.id %>"><%= r.firstName %></a><% }); %><% if (g.namesTail) { %> <%= g.namesTail %><% } %></div>
              <div class="podium-subline muted"><%= g.subLine %></div>
            <% } else { %>
              <% var r = g.members[0]; %>
              <a class="podium-avatar" href="/u/<%= r.id %>">
                <% if (r.avatar_path) { %>
                  <img src="/uploads/<%= r.avatar_path %>" alt="" width="64" height="64" style="width:100%;height:100%;object-fit:cover;" />
                <% } else { %>
                  <%= initials(r.name) || '?' %>
                <% } %>
              </a>
              <div class="podium-name"><a href="/u/<%= r.id %>"><%= r.name || 'Guest' %></a></div>
            <% } %>
            <div class="podium-bar"><span class="podium-bar-label"><%= g.barLabel %></span></div>
          </div>
        <% }); %>
      </div>
    <% } %>

    <h2 class="lb-standings-title">Full standings</h2>
    <ol class="leaderboard-list">
      <%
        // This list is the COMPLETE ranked field: every guest, ranks 1..N, in
        // order. The podium above is only a highlight on top — so the top
        // guests intentionally appear both places, tied or not.
      %>
      <% rows.forEach(function (r) { %>
        <li class="leaderboard-row<%= (guest && guest.id === r.id) ? ' is-me' : '' %>">
          <span class="rank rank-n"><%= r.rankLabel %></span>

          <a class="lb-guest" href="/u/<%= r.id %>">
            <% if (r.avatar_path) { %>
              <img class="lb-avatar"
                   src="/uploads/<%= r.avatar_path %>"
                   alt=""
                   width="40" height="40" />
            <% } else { %>
              <span class="lb-avatar-empty" aria-hidden="true">
                <%= initials(r.name) || '?' %>
              </span>
            <% } %>
            <span class="lb-name"><%= r.name || 'Guest' %></span>
          </a>

          <span class="lb-badges">
            <% r.badges.slice(0, badgeCap).forEach(function (b) { %>
              <a href="/badge/<%= b.code %>" title="<%= b.name %>">
                <img class="lb-badge-icon"
                     src="<%= b.art_path %>"
                     alt="<%= b.name %>"
                     width="24" height="24" />
              </a>
            <% }); %>
            <% if (r.badges.length > badgeCap) { %>
              <span class="lb-badge-more">+<%= r.badges.length - badgeCap %></span>
            <% } %>
          </span>

          <span class="lb-points">
            <strong><%= r.points %></strong>
            <span class="lb-points-label"> pt<%= r.points === 1 ? '' : 's' %></span>
          </span>
        </li>
      <% }); %>
    </ol>
  <% } %>

<%- include('partials/footer') %>
