<!-- src/views/leaderboard.ejs -->
<%- include('partials/head') %>
<%- include('partials/header') %>

  <h1 class="page-title center">Leaderboard</h1>
  <div class="heart-divider" style="color:var(--color-primary);"><%- include('partials/heart', { size: 20 }) %></div>

  <% if (rows.length === 0) { %>
    <p class="muted center">No guests yet.</p>
  <% } else { %>
    <%
      var top3 = rows.slice(0, 3);
      var rest = rows.slice(3);
      // podium order: 2nd, 1st, 3rd
      var podiumOrder = top3.length === 1
        ? [top3[0]]
        : top3.length === 2
          ? [top3[1], top3[0]]
          : [top3[1], top3[0], top3[2]];
    %>

    <% if (top3.length > 0) { %>
      <div class="podium">
        <% podiumOrder.forEach(function (r) { %>
          <div class="podium-slot rank-<%= r.rank %>">
            <div class="podium-avatar">
              <% if (r.avatar_path) { %>
                <img src="/uploads/<%= r.avatar_path %>" alt="" width="64" height="64" style="width:100%;height:100%;object-fit:cover;" />
              <% } else { %>
                <%= (r.name || '?').trim().charAt(0).toUpperCase() || '?' %>
              <% } %>
            </div>
            <div class="podium-name"><%= r.name || 'Guest' %></div>
            <div class="podium-bar"><%= r.rank %></div>
          </div>
        <% }); %>
      </div>
    <% } %>

    <% if (rest.length > 0) { %>
      <ol class="leaderboard-list" start="4">
        <% rest.forEach(function (r) { %>
          <li class="leaderboard-row<%= (guest && guest.id === r.id) ? ' is-me' : '' %>">
            <span class="rank rank-n"><%= r.rank %></span>

            <a class="lb-guest" href="/u/<%= r.id %>">
              <% if (r.avatar_path) { %>
                <img class="lb-avatar"
                     src="/uploads/<%= r.avatar_path %>"
                     alt=""
                     width="40" height="40" />
              <% } else { %>
                <span class="lb-avatar-empty" aria-hidden="true">
                  <%= (r.name || '?').trim().charAt(0).toUpperCase() || '?' %>
                </span>
              <% } %>
              <span class="lb-name"><%= r.name || 'Guest' %></span>
            </a>

            <span class="lb-badges">
              <% r.badges.forEach(function (b) { %>
                <img class="lb-badge-icon"
                     src="<%= b.art_path %>"
                     alt="<%= b.name %>"
                     title="<%= b.name %>"
                     width="24" height="24" />
              <% }); %>
            </span>

            <span class="lb-points">
              <strong><%= r.points %></strong>
              <span class="lb-points-label"> pt<%= r.points === 1 ? '' : 's' %></span>
            </span>
          </li>
        <% }); %>
      </ol>
    <% } %>
  <% } %>

<%- include('partials/footer') %>
