<!-- src/views/leaderboard.ejs -->
<%- include('partials/head') %>
<%- include('partials/header') %>

  <h1 class="page-title center">Leaderboard</h1>
  <div class="heart-divider" style="color:var(--color-primary);"><%- include('partials/heart', { size: 20 }) %></div>

  <% if (rows.length === 0) { %>
    <p class="muted center">No guests yet.</p>
  <% } else { %>
    <%
      // All podium/tie/rank decisions are precomputed in the route (issue
      // #626): podiumGroups (rank, ordinal, points, isTie, the FULL tied
      // membership), showPodium, and each row's plain dense rankLabel. This
      // view only renders that structure plus its own presentation-only
      // concerns — the 9-face cluster cap and the pt/pts word — never
      // re-bucketing rows or re-deriving tie membership.
      function ptsWord(p) { return p === 1 ? 'pt' : 'pts'; }
      var PODIUM_CLUSTER_CAP = 9; // faces shown per tier; the rest fold into "+N"
    %>

    <% if (!showPodium) { %>
      <p class="podium-low-spread center muted">It's a clean sweep — everyone's tied.</p>
    <% } else { %>
      <div class="podium">
        <% podiumGroups.forEach(function (g) { %>
          <div class="podium-slot rank-<%= g.rank %>">
            <% if (g.rank === 1) { %>
              <div class="podium-crown" aria-hidden="true"><%- include('partials/crown', { size: 34 }) %></div>
            <% } %>

            <%# The tier's cluster grows to fit the tie, up to a cap of 9 faces;
                a larger tie folds the rest into a "+N" chip so a 25-way tie
                stays a compact cluster, not a wall of faces. %>
            <% var shown = g.members.slice(0, PODIUM_CLUSTER_CAP); %>
            <% var extra = g.members.length - shown.length; %>
            <div class="podium-cluster<%= g.isTie ? ' is-tie' : '' %>">
              <% shown.forEach(function (r) { %>
                <a class="podium-cluster-avatar" href="/u/<%= r.id %>" title="<%= r.name || 'Guest' %>">
                  <% if (r.avatar_path) { %>
                    <img src="/uploads/<%= r.avatar_path %>" alt="<%= r.name || 'Guest' %>" />
                  <% } else { %>
                    <span class="podium-cluster-initials"><%= initials(r.name) || '?' %></span>
                  <% } %>
                </a>
              <% }); %>
              <% if (extra > 0) { %>
                <span class="podium-cluster-more">+<%= extra %></span>
              <% } %>
            </div>

            <%# No names here — the avatars carry identity (each links to a
                profile, with a name tooltip) and the full standings below name
                everyone. %>
            <div class="podium-block">
              <span class="podium-place"><%= g.ordinal %></span>
              <span class="podium-points"><%= g.points %> <%= ptsWord(g.points) %><%= g.isTie ? ' each' : '' %></span>
            </div>
          </div>
        <% }); %>
      </div>
    <% } %>

    <h2 class="lb-standings-title">Full standings</h2>
    <ol class="leaderboard-list">
      <%
        // This list is the COMPLETE ranked field: every guest, ranks 1..N, in
        // order. The podium above is only a highlight on top — so the top
        // guests intentionally appear both places, tied or not.
      %>
      <% rows.forEach(function (r) { %>
        <li class="leaderboard-row<%= (guest && guest.id === r.id) ? ' is-me' : '' %>">
          <span class="rank rank-n"><%= r.rankLabel %></span>

          <a class="lb-guest" href="/u/<%= r.id %>">
            <% if (r.avatar_path) { %>
              <img class="lb-avatar"
                   src="/uploads/<%= r.avatar_path %>"
                   alt=""
                   width="40" height="40" />
            <% } else { %>
              <span class="lb-avatar-empty" aria-hidden="true">
                <%= initials(r.name) || '?' %>
              </span>
            <% } %>
            <span class="lb-name"><%= r.name || 'Guest' %></span>
          </a>

          <span class="lb-badges">
            <% r.badges.slice(0, badgeCap).forEach(function (b) { %>
              <a href="/badge/<%= b.code %>" title="<%= b.name %>">
                <%- include('partials/badge-art', { badge: b, imgClass: 'lb-badge-icon', width: 24, height: 24 }) %>
              </a>
            <% }); %>
            <% if (r.badges.length > badgeCap) { %>
              <span class="lb-badge-more">+<%= r.badges.length - badgeCap %></span>
            <% } %>
          </span>

          <span class="lb-points">
            <strong><%= r.points %></strong>
            <span class="lb-points-label"> <%= ptsWord(r.points) %></span>
          </span>
        </li>
      <% }); %>
    </ol>
  <% } %>

<%- include('partials/footer') %>
