<!-- src/views/gallery.ejs -->
<%- include('partials/head') %>
<%- include('partials/header') %>

  <h1 class="page-title">Gallery</h1>
  <p class="muted">
    <%= total %> photo<%= total === 1 ? '' : 's' %> from the weekend.
  </p>

  <!-- View switcher -->
  <nav class="gallery-switcher" aria-label="Gallery views">
    <a class="gallery-switch-link<%= view === 'recent' ? ' gallery-switch-active' : '' %>"
       href="?view=recent">Recent</a>
    <a class="gallery-switch-link<%= view === 'task'   ? ' gallery-switch-active' : '' %>"
       href="?view=task">By task</a>
    <a class="gallery-switch-link<%= view === 'user'   ? ' gallery-switch-active' : '' %>"
       href="?view=user">By person</a>
  </nav>

  <% if (groups.length === 0 && photos.length === 0) { %>
    <p class="muted">No photos yet. Be the first to share one!</p>
  <% } %>

  <%
    /* Render a single flat grid of photo items.
       Used both in the recent view and inside each grouped section. */
    function renderGrid(items) {
  %>
    <div class="gallery-grid" id="galleryGrid">
      <% items.forEach(function (p) { %>
        <figure class="gallery-item">
          <a
            class="gallery-thumb-btn"
            href="/p/<%= p.submission_id %>"
            aria-label="View photo for <%= p.task_title %>"
          >
            <img
              class="gallery-thumb"
              src="/thumbs/<%= p.thumb_path %>"
              alt="<%= p.task_title %>"
              loading="lazy"
              width="400"
              height="400"
            />
          </a>
          <figcaption class="gallery-caption">
            <a class="gallery-task" href="/gallery?task=<%= p.task_id %>"><%= p.task_title %></a>
            <span class="gallery-by">by
              <a href="/u/<%= p.guest_id %>"><%= p.guest_name || 'Guest' %></a>
            </span>
            <% if (p.caption) { %>
              <span class="gallery-text"><%= p.caption %></span>
            <% } %>
          </figcaption>
        </figure>
      <% }); %>
    </div>
  <% } %>

  <% if (groups.length > 0) { %>
    <% groups.forEach(function (g) { %>
      <h2 class="gallery-group-heading"><%= g.heading %></h2>
      <%- renderGrid(g.photos) %>
    <% }); %>
  <% } else if (photos.length > 0) { %>
    <%- renderGrid(photos) %>

    <% if (totalPages > 1) { %>
      <nav class="pagination" aria-label="Gallery pages">
        <% if (page > 1) { %>
          <a class="page-link" href="/gallery?page=<%= page - 1 %>">&larr; Newer</a>
        <% } else { %>
          <span class="page-link disabled">&larr; Newer</span>
        <% } %>

        <span class="page-status">Page <%= page %> of <%= totalPages %></span>

        <% if (page < totalPages) { %>
          <a class="page-link" href="/gallery?page=<%= page + 1 %>">Older &rarr;</a>
        <% } else { %>
          <span class="page-link disabled">Older &rarr;</span>
        <% } %>
      </nav>
    <% } %>
  <% } %>

<%- include('partials/footer') %>
