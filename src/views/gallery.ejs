<!-- src/views/gallery.ejs -->
<%- include('partials/head') %>
<%- include('partials/header') %>

  <h1 class="page-title gallery-title">
    Gallery
    <span class="gallery-count"><%= total %> photo<%= total === 1 ? '' : 's' %></span>
  </h1>

  <!-- View switcher — the app-wide chip pattern (same component as the Tasks
       page filters): sage solid = active, outline = inactive. -->
  <nav class="task-filters" aria-label="Gallery views">
    <a class="chip-filter<%= view === 'recent' ? ' chip-filter-active' : '' %>"
       href="?view=recent">Recent</a>
    <a class="chip-filter<%= view === 'task'   ? ' chip-filter-active' : '' %>"
       href="?view=task">By task</a>
    <a class="chip-filter<%= view === 'user'   ? ' chip-filter-active' : '' %>"
       href="?view=user">By person</a>
  </nav>

  <% if (view === 'task' || view === 'user') { %>
    <%# The GET form is the no-JS fallback (server-side substring filter).
        In BOTH grouped views the same input is also the LIVE filter (issue
        #527): /js/gallery.js listens on #person-search / #task-search and
        hides non-matching [data-person-section] / [data-task-section]
        sections as the guest types. One control, one behavior. %>
    <form class="gallery-search" method="get">
      <input type="hidden" name="view" value="<%= view %>">
      <input
        type="search"
        name="q"
        id="<%= view === 'user' ? 'person-search' : 'task-search' %>"
        autocomplete="off"
        value="<%= q %>"
        placeholder="<%= view === 'user' ? 'Search people' : 'Search tasks' %>"
        aria-label="<%= view === 'user' ? 'Search people' : 'Search tasks' %>"
      >
    </form>
  <% } %>

  <% if (groups.length === 0 && photos.length === 0) { %>
    <p class="muted">No photos yet. Be the first to share one!</p>
  <% } %>

  <%# Crowd-favorite rank lookup (issue #788): submission_id -> rank (1 is
      gold), supplied by the route from ONE scoring.crowdFavorites() call.
      Defaults to an empty lookup when a caller renders this view without it,
      so the crown mark below simply matches nothing rather than throwing. %>
  <% var crownRank = (typeof crownRank !== 'undefined' && crownRank) ? crownRank : {}; %>

  <%
    /* One photo tile: thumbnail linking into the feed at that photo, with a
       like-count badge only when likes exist (no badge at 0). A top-5
       crowd-favorite photo also wears its crown (issue #788). overlayCount
       and overlayHref, when given, render the "+N" scrim on this tile
       (grouped previews, issue #251) and repoint the tile at the full list. */
    function renderTile(p, overlayCount, overlayHref) {
  %>
    <figure class="gallery-item">
      <a
        class="gallery-thumb-btn"
        href="<%= overlayCount ? overlayHref : '/feed?from=' + p.submission_id + '#photo-' + p.submission_id %>"
        aria-label="<%= overlayCount ? 'See all photos in this section' : 'View photo for ' + (p.task_title || 'a shared memory') %>"
      >
        <img
          class="gallery-thumb"
          src="/thumbs/<%= p.thumb_path %>"
          alt="<%= p.task_title || 'a shared memory' %>"
          loading="lazy"
          width="400"
          height="400"
        />
        <% if (!overlayCount && crownRank[p.submission_id]) { %>
          <%- include('partials/crowd-favorite-mark', { rank: crownRank[p.submission_id] }) %>
        <% } %>
        <% if (overlayCount) { %>
          <span class="tile-more">+<%= overlayCount %></span>
        <% } else if (p.like_count > 0) { %>
          <span class="tile-like-badge"><span aria-hidden="true">&hearts;</span> <%= p.like_count %></span>
        <% } %>
      </a>
    </figure>
  <% } %>

  <%
    /* A flat grid of photo tiles — the recent wall and each grouped preview. */
    function renderGrid(items, groupTotal, overlayHref) {
  %>
    <div class="gallery-grid" id="galleryGrid">
      <% items.forEach(function (p, i) { %>
        <% var overflow = groupTotal > items.length && i === items.length - 1; %>
        <%- renderTile(p, overflow ? groupTotal - items.length : 0, overlayHref) %>
      <% }); %>
    </div>
  <% } %>

  <% if (groups.length > 0) { %>
    <% groups.forEach(function (g) { %>
      <%
        /* g.task_id is null for the Memories group (issue #247, task-free
           rows partition together) — there is no single-task filter to link
           to, so the heading falls back to the unfiltered recent view rather
           than building a broken "?task=" link. */
        var sectionHref = view === 'task'
          ? (g.task_id ? '/gallery?view=recent&task=' + g.task_id : '/gallery?view=recent')
          : '/u/' + g.guest_id;
      %>
      <%# The live-filter hook carries the section's own heading, so the
          client filter matches exactly what the guest can read on screen.
          In the By-task view that heading is the task title — or the literal
          "Memories" for the task-free group (issue #247), which therefore
          filters on the word "Memories" like any other section. %>
      <section class="gallery-group"<% if (view === 'user') { %> data-person-section="<%= g.heading %>"<% } else if (view === 'task') { %> data-task-section="<%= g.heading %>"<% } %>>
        <a class="gallery-group-head" href="<%= sectionHref %>">
          <% if (view === 'user') { %>
            <span class="gallery-person-avatar">
              <% if (g.avatar_path) { %>
                <img src="/uploads/<%= g.avatar_path %>" alt="" width="34" height="34" />
              <% } else { %>
                <%= initials(g.heading) || '?' %>
              <% } %>
            </span>
          <% } %>
          <h2 class="gallery-group-heading"><%= g.heading %></h2>
          <span class="gallery-group-count"><%= g.total %> photo<%= g.total === 1 ? '' : 's' %></span>
          <span class="gallery-group-chevron" aria-hidden="true">&rsaquo;</span>
        </a>
        <%- renderGrid(g.photos, g.total, sectionHref) %>
      </section>
    <% }); %>
  <% } else if (photos.length > 0) { %>
    <%- renderGrid(photos, photos.length, null) %>

    <% if (page < totalPages) { %>
      <nav class="show-more" aria-label="More photos">
        <a class="btn btn-secondary"
           href="/gallery?view=recent<%= taskFilter ? '&task=' + taskFilter : '' %>&page=<%= page + 1 %>">Show more</a>
      </nav>
    <% } %>
  <% } %>

<%# Both grouped views get the live filter (#527); the recent view has no
    search control, so it loads neither script. %>
<% if (view === 'user' || view === 'task') { %>
  <script src="/js/filter.js" defer></script>
  <script src="/js/gallery.js" defer></script>
<% } %>
<% if (groups.length === 0 && page < totalPages) { %>
  <script src="/js/gallery-more.js" defer></script>
<% } %>
<%- include('partials/footer') %>
