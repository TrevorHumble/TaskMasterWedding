<!-- src/views/admin-photos.ejs -->
<%- include('partials/head') %>
<%- include('partials/header') %>

<%
  // =====================================================================
  // Issue #259 — full guest-gallery parity, wired to real data. This
  // transcribes the owner-approved phase-1 prototype (visual loop,
  // 2026-07-19): same classes/markup shape, real server-side view/search
  // (GET /admin/photos ?view=/?q=, src/routes/admin.js), real favorite state
  // (src/services/favorites.js), real moderation. The five-code give-a-badge
  // picker this view used to drive (src/services/photo-badges.js,
  // badge_winners) is RETIRED (issue #661's one-badge-system consolidation) —
  // ranking and awarding a task's photos now lives on its own page,
  // GET/POST /admin/tasks/:id/rank (linked from this page's task-scoped view,
  // below). Locals from the route: photos (EVERY submission, incl.
  // taken-down — an admin wall shows everything; the guest gallery's
  // taken-down exclusion does not apply here — EXCEPT on a scoped
  // view=task&task=<id> request, issue #748, where photos is already
  // narrowed to that one task's submissions only), favorites (favorited
  // submissions, same "show everything" rule), groups (view=task/user only,
  // already q-filtered, LIVE submissions only — EXCEPT a scoped request,
  // which yields at most one group holding ALL of that task's submissions,
  // taken-down included, with q ignored entirely), view, q, taskScope
  // (issue #748 — the scoped task's { id, title } row, or null when
  // unscoped; picks the empty-state branch below, and the rank-page entry
  // point below), taskScopeId (the same scope already rendered down to a
  // bare id or '', so every mutating form writes it as flatly as it writes
  // view/q — the route resolves the null, not the template).
  //
  // View switching and search are real navigation (mirrors src/views/gallery.ejs
  // exactly) — only the grid<->feed toggle is client-side, because the inline
  // feed is not a separate route (issue #259's Touches list keeps this one
  // view file / one route).
  var showGroups = view === 'task' || view === 'user';
  var showSearch = showGroups;
%>

<h1 class="page-title gallery-title" data-gallery-heading data-gallery-chrome>
  Photos
  <span class="gallery-count"><%= photos.length %> photo<%= photos.length === 1 ? '' : 's' %></span>
</h1>

<% if (msg) { %>
  <p class="flash flash-ok" role="status"><%= msg %></p>
<% } %>

<!-- View switcher — same chip pattern as the guest gallery (real navigation,
     mirrors gallery.ejs), plus a heart-only Favorites pill. -->
<nav class="task-filters" aria-label="Photo views" data-gallery-chrome>
  <a class="chip-filter<%= view === 'recent' ? ' chip-filter-active' : '' %>" href="?view=recent">Recent</a>
  <a class="chip-filter<%= view === 'task'   ? ' chip-filter-active' : '' %>" href="?view=task">By task</a>
  <a class="chip-filter<%= view === 'user'   ? ' chip-filter-active' : '' %>" href="?view=user">By person</a>
  <a class="chip-filter chip-fav<%= view === 'fav' ? ' chip-filter-active' : '' %>" href="?view=fav" aria-label="Favorites" title="Favorites">
    <svg viewBox="0 0 24 24" aria-hidden="true" class="chip-fav-heart">
      <path d="M12 21s-8.5-5.3-8.5-11.2A4.8 4.8 0 0 1 12 6.6a4.8 4.8 0 0 1 8.5 3.2C20.5 15.7 12 21 12 21z"/>
    </svg>
  </a>
</nav>

<!-- Search — only on By task / By person (Recent & Favorites are plain
     walls, AC3). Real GET form, same shape as gallery.ejs. -->
<% if (showSearch) { %>
  <form class="gallery-search" method="get" data-gallery-chrome>
    <input type="hidden" name="view" value="<%= view %>">
    <input
      type="search"
      name="q"
      value="<%= q %>"
      placeholder="<%= view === 'user' ? 'Search people' : 'Search tasks' %>"
      aria-label="<%= view === 'user' ? 'Search people' : 'Search tasks' %>"
    >
  </form>
<% } %>

<%
  // ---- Gallery tile: square thumbnail (opens the feed at that photo) with a
  //      hover-reveal quick favorite heart. (The give-a-badge button this
  //      comment used to also describe is retired — issue #661.) ----
  function adminTile(p, panel) {
%>
  <figure class="gallery-item admin-tile<%= p.taken_down ? ' is-down' : '' %>">
    <button
      type="button"
      class="gallery-thumb-btn admin-tile-open"
      aria-label="Open photo by <%= p.guest_name || ('Guest #' + p.guest_id) %> in the feed"
      data-open-feed="<%= p.id %>"
    >
      <img
        class="gallery-thumb"
        src="/thumbs/<%= p.thumb_path %>"
        alt="<%= p.task_title || 'a shared memory' %>"
        loading="lazy"
        width="400"
        height="400"
      />
    </button>

    <% if (p.taken_down) { %>
      <span class="admin-tile-down">Taken down</span>
      <% if (p.resubmitted) { %>
        <span class="admin-tile-resub">Resubmitted &mdash; review</span>
      <% } %>
    <% } %>

    <div class="admin-tile-actions">
      <form method="post" action="/admin/photos/<%= p.id %>/favorite">
        <input type="hidden" name="view" value="<%= view %>">
        <input type="hidden" name="q" value="<%= q %>">
        <input type="hidden" name="panel" value="<%= panel %>">
        <input type="hidden" name="task" value="<%= taskScopeId %>">
        <button
          type="submit"
          class="admin-tile-btn admin-fav<%= p._fav ? ' admin-fav-on' : '' %>"
          aria-pressed="<%= p._fav ? 'true' : 'false' %>"
          aria-label="Favorite this photo"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 21s-8.5-5.3-8.5-11.2A4.8 4.8 0 0 1 12 6.6a4.8 4.8 0 0 1 8.5 3.2C20.5 15.7 12 21 12 21z"/>
          </svg>
        </button>
      </form>
    </div>
  </figure>
<% } %>

<%
  function adminGrid(list, panel) {
%>
  <div class="gallery-grid">
    <% list.forEach(function (p) { %><%- adminTile(p, panel) %><% }); %>
  </div>
<% } %>

<% if (taskScope) { %>
  <%# Entry point into the rank-and-award page (issue #661 design: "entry
      points link to it: ... the admin photos / task surface") — only
      rendered on a task-scoped view (?view=task&task=<id>), the one place
      this admin surface already knows which single task it is looking at. %>
  <p class="page-actions" data-gallery-chrome>
    <a href="/admin/tasks/<%= taskScope.id %>/rank">Rank &amp; award this task&rsquo;s photos</a>
  </p>
<% } %>

<div data-gallery-chrome>
  <% if (showGroups) { %>
    <% if (taskScope && groups.length === 0) { %>
      <%# Scoped to one task with zero submissions (issue #748 AC2) — the
          same empty-state copy the unscoped Recent wall uses below (the
          Favorites wall has its own wording), so a scoped host sees a
          visible message, never a blank body. %>
      <p class="muted">No photos submitted yet.</p>
    <% } else { %>
      <% groups.forEach(function (g) { %>
        <section class="gallery-group">
          <div class="gallery-group-head">
            <% if (view === 'user') { %>
              <span class="gallery-person-avatar"><%= initials(g.heading) || '?' %></span>
            <% } %>
            <h2 class="gallery-group-heading"><%= g.heading %></h2>
            <span class="gallery-group-count"><%= g.photos.length %> photo<%= g.photos.length === 1 ? '' : 's' %></span>
          </div>
          <%- adminGrid(g.photos, '') %>
        </section>
      <% }); %>
    <% } %>
  <% } else if (view === 'fav') { %>
    <% if (favorites.length === 0) { %>
      <p class="muted">No favorites yet. Tap the heart on a photo to pin it here.</p>
    <% } else { %>
      <%- adminGrid(favorites, '') %>
    <% } %>
  <% } else { %>
    <% if (photos.length === 0) { %>
      <p class="muted">No photos submitted yet.</p>
    <% } else { %>
      <%- adminGrid(photos, '') %>
    <% } %>
  <% } %>
</div>

<%
  // One comment row (the .feed-comment-item the guest thread uses), with the
  // host's visible inline Hide / Restore. `clamp` toggles the 2-line ellipsis
  // used in the card preview (the lone comment and the dialog thread show full
  // text). Author links to the public profile with the same 'Guest' fallback as
  // the guest feed (src/views/feed.ejs). Same local-function idiom as adminTile.
  function adminCommentRow(c, clamp) {
%>
  <div class="feed-comment-item admin-comment-item<%= c.hidden ? ' is-hidden' : '' %>">
    <p class="feed-comment<%= clamp ? ' admin-comment-clamp' : '' %>"><a href="/u/<%= c.guest_id %>"><%= c.name || 'Guest' %></a> <%= c.body %></p>
    <% if (c.hidden) { %>
      <form method="post" action="/admin/comments/<%= c.id %>/restore" class="admin-comment-actionform">
        <input type="hidden" name="view" value="<%= view %>">
        <input type="hidden" name="q" value="<%= q %>">
        <input type="hidden" name="panel" value="feed">
        <input type="hidden" name="task" value="<%= taskScopeId %>">
        <button type="submit" class="admin-comment-action admin-comment-restore">Restore</button>
      </form>
    <% } else { %>
      <form method="post" action="/admin/comments/<%= c.id %>/hide" class="admin-comment-actionform" data-confirm="Hide this comment? Guests will no longer see it.">
        <input type="hidden" name="view" value="<%= view %>">
        <input type="hidden" name="q" value="<%= q %>">
        <input type="hidden" name="panel" value="feed">
        <input type="hidden" name="task" value="<%= taskScopeId %>">
        <button type="submit" class="admin-comment-action admin-comment-hide">Hide</button>
      </form>
    <% } %>
  </div>
<% } %>

<!-- ===================== FEED (parity with guest feed) ===================== -->
<!-- Client-side only (no separate route, issue #259): tapping any tile above
     shows this same server-rendered section, scrolled to that photo. Same
     card shape as src/views/feed.ejs; like -> favorite. (comment ->
     give-a-badge used to be the second swap here too, before issue #661
     retired that control.) -->
<section data-view-panel="feed" hidden>
  <p class="back-link"><a href="?view=<%= view %><%= q ? '&q=' + encodeURIComponent(q) : '' %>" data-feed-back>&larr; Back to photos</a></p>
  <div class="feed">
    <% photos.forEach(function (p) { %>
      <article id="feed-photo-<%= p.id %>" class="feed-item admin-feed-item<%= p.taken_down ? ' is-down' : '' %>">
        <%# Card header: uploader name + the contextual ⋯ menu (issue #684).
            Take down / Restore moved OUT of the Give-a-badge dialog and into
            this kebab, mirroring the guest owner-menu (#387,
            partials/photo-owner-menu.ejs) so moderation sits where the host
            looks — on the photo — not buried behind the badge button. Native
            <details>/<summary>: opens with no JS. The confirm is admin.js's
            delegated data-confirm handler. %>
        <div class="feed-by admin-feed-by">
          <span class="admin-feed-name"><%= p.guest_name || ('Guest #' + p.guest_id) %></span>
          <details class="photo-owner-menu admin-photo-menu">
            <summary class="photo-owner-menu-trigger" aria-label="Photo options">&#8943;</summary>
            <div class="photo-owner-menu-panel">
              <% if (p.taken_down) { %>
                <form method="post" action="/admin/photos/<%= p.id %>/restore" data-confirm="Restore this photo? Guests will see it again.">
                  <input type="hidden" name="view" value="<%= view %>">
                  <input type="hidden" name="q" value="<%= q %>">
                  <input type="hidden" name="panel" value="feed">
                  <input type="hidden" name="task" value="<%= taskScopeId %>">
                  <button type="submit" class="photo-owner-menu-item">Restore photo</button>
                </form>
              <% } else { %>
                <form method="post" action="/admin/photos/<%= p.id %>/takedown" data-confirm="Take this photo down? Guests will no longer see it.">
                  <input type="hidden" name="view" value="<%= view %>">
                  <input type="hidden" name="q" value="<%= q %>">
                  <input type="hidden" name="panel" value="feed">
                  <input type="hidden" name="task" value="<%= taskScopeId %>">
                  <button type="submit" class="photo-owner-menu-item photo-owner-delete">Take down photo</button>
                </form>
              <% } %>
            </div>
          </details>
        </div>

        <%# Parity with the guest feed (issue #673): inside the admin inline
            feed, tapping the photo opens the full-resolution original in the
            shared lightbox — the same gesture a guest gets in their feed.
            Moderation variant: no like/comment hooks, so the overlay is
            image + caption only. Taken-down photos open too (files stay on
            disk) so a host can re-examine what was hidden. %>
        <button
          type="button"
          class="admin-feed-photo-btn js-lightbox"
          aria-label="View full-resolution photo"
          data-lightbox-group="admin-feed"
          data-lightbox-photo="<%= p.photo_path %>"
          data-lightbox-alt="<%= p.task_title || 'a shared memory' %>"
          data-lightbox-by="<%= p.guest_name || ('Guest #' + p.guest_id) %><%= p.taken_down ? ' — taken down' : '' %>"
          data-lightbox-caption="<%= p.task_title || 'Memory' %>"
        >
          <img
            class="feed-photo"
            src="/thumbs/<%= p.thumb_path %>"
            alt="<%= p.task_title || 'a shared memory' %>"
            loading="lazy"
          />
          <%# Taken-down photo in the viewer reads exactly like the grid tile
              (issue #684): grayscale image + the "Taken down" pill laid over
              the photo, same classes as the grid (.admin-tile-down /
              .admin-tile-resub) so the two surfaces stay one component. %>
          <% if (p.taken_down) { %>
            <span class="admin-tile-down">Taken down</span>
            <% if (p.resubmitted) { %>
              <span class="admin-tile-resub">Resubmitted &mdash; review</span>
            <% } %>
          <% } %>
        </button>

        <% if (p.caption) { %>
          <p class="feed-caption"><%= p.caption %></p>
        <% } %>

        <div class="feed-actionbar">
          <div class="feed-actions-left">
            <form method="post" action="/admin/photos/<%= p.id %>/favorite" class="like-form">
              <input type="hidden" name="view" value="<%= view %>">
              <input type="hidden" name="q" value="<%= q %>">
              <input type="hidden" name="panel" value="feed">
              <input type="hidden" name="task" value="<%= taskScopeId %>">
              <button
                type="submit"
                class="like-button admin-feed-fav<%= p._fav ? ' like-button-liked' : '' %>"
                aria-pressed="<%= p._fav ? 'true' : 'false' %>"
                aria-label="Favorite this photo"
              >
                <svg class="like-heart" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M12 21s-8.5-5.3-8.5-11.2A4.8 4.8 0 0 1 12 6.6a4.8 4.8 0 0 1 8.5 3.2C20.5 15.7 12 21 12 21z"/>
                </svg>
                <span class="like-count">Favorite</span>
              </button>
            </form>
          </div>

          <span class="points-count"><%= p.photo_bonus %> <%= p.photo_bonus === 1 ? 'point' : 'points' %></span>
        </div>

        <% if (p.task_title) { %>
          <p class="feed-task-line">for &ldquo;<%= p.task_title %>&rdquo;</p>
        <% } else { %>
          <p class="feed-task-line">a shared memory</p>
        <% } %>

        <%# Comments in context (issue #684): each photo's comments render
            right under it so the host judges them where they live, instead of
            on a separate Comments page. A live comment carries a quiet Hide; a
            hidden one stays visible to the host, struck-through, with Restore.
            Guests never see a hidden comment. Real data, attached by GET
            /admin/photos (src/routes/admin.js) — oldest-first, so slice(-2)
            below surfaces the 2 most recent. Posts to the existing
            /admin/comments/:id/hide|restore handlers, which now redirect
            back to this feed card, never the removed Comments page. %>
        <% var _cmts = p.comments || []; %>
        <% if (_cmts.length === 1) { %>
          <%# A lone comment: shown in full (no clamp) with its visible, inline
              Hide (Restore if hidden) — the same inline placement every comment
              gets, so there is no lone-vs-thread inconsistency, and no "See all
              1". %>
          <% var _c1 = _cmts[0]; %>
          <div class="feed-comments admin-feed-comments">
            <%- adminCommentRow(_c1, false) %>
          </div>
        <% } else if (_cmts.length > 1) { %>
          <%# A thread: every comment carries the SAME visible, inline Hide
              (Restore if hidden) — consistent placement, no floating ⋯ dropdown
              (the card's content-visibility:auto containment would clip one).
              Each comment's TEXT is clamped to 2 lines with a real trailing
              ellipsis (.admin-comment-clamp / -webkit-line-clamp), so a long
              comment reads as truncated ("…"), never an unfinished thought,
              while its Hide stays beside it. The preview shows the 2 most
              recent; "See all N" opens the full, unclamped thread in a
              top-layer <dialog>. Posts to the existing /admin/comments/:id/
              hide|restore handlers; Restore returns to this feed (panel=feed),
              never the removed Comments page. %>
          <div class="feed-comments admin-feed-comments">
            <% _cmts.slice(-2).forEach(function (c) { %><%- adminCommentRow(c, true) %><% }); %>
            <button
              type="button"
              class="see-all-comments"
              data-open-admin-comments="<%= p.id %>"
            >See all <%= _cmts.length %> comments</button>
          </div>

            <dialog
              class="comments-dialog admin-comments-dialog"
              id="admin-comments-dialog-<%= p.id %>"
              aria-labelledby="admin-comments-title-<%= p.id %>"
            >
              <div class="comments-dialog-header">
                <img class="comments-dialog-thumb" src="/thumbs/<%= p.thumb_path %>" alt="" />
                <h2 class="comments-dialog-title" id="admin-comments-title-<%= p.id %>">Comments</h2>
                <button type="button" class="comments-dialog-close" data-close-admin-comments aria-label="Close comments">&times;</button>
              </div>
              <div class="comments-dialog-thread">
                <% _cmts.forEach(function (c) { %><%- adminCommentRow(c, false) %><% }); %>
              </div>
            </dialog>
          <% } %>
      </article>
    <% }); %>
  </div>
  <p class="back-link"><a href="?view=<%= view %><%= q ? '&q=' + encodeURIComponent(q) : '' %>" data-feed-back>&larr; Back to photos</a></p>
</section>

<script src="/js/admin.js" defer></script>
<script src="/js/lightbox.js" defer></script>
<script>
  (function () {
    // ------- Grid <-> Feed toggle -------
    // View/search are real navigation now (server-rendered per ?view=/?q=,
    // src/routes/admin.js); only the inline feed needs client-side show/hide,
    // since it is not a separate route (issue #259's Touches list).
    var chrome = document.querySelectorAll('[data-gallery-chrome]');
    var feedPanel = document.querySelector('[data-view-panel="feed"]');

    function showFeed() {
      chrome.forEach(function (el) { el.hidden = true; });
      if (feedPanel) feedPanel.hidden = false;
    }
    function showGrid() {
      chrome.forEach(function (el) { el.hidden = false; });
      if (feedPanel) feedPanel.hidden = true;
    }
    function openFeedAt(id) {
      showFeed();
      var card = document.getElementById('feed-photo-' + id);
      if (card) card.scrollIntoView({ block: 'start' });
      else window.scrollTo(0, 0);
    }

    document.addEventListener('click', function (e) {
      var open = e.target.closest('[data-open-feed]');
      if (!open) return;
      openFeedAt(open.getAttribute('data-open-feed'));
    });
    document.addEventListener('click', function (e) {
      if (!e.target.closest('[data-feed-back]')) return;
      e.preventDefault();
      showGrid();
      window.scrollTo(0, 0);
    });

    // A favorite/badge/moderation action posted from inside the feed carries
    // panel=feed, so the server's redirect lands back here with
    // #feed-photo-<id> (src/routes/admin.js's redirectToPhotos) — reopen the
    // feed at that card instead of showing the grid on reload.
    (function () {
      var m = /^#feed-photo-(\d+)$/.exec(window.location.hash);
      if (m) openFeedAt(m[1]);
    })();

    // ------- Comments thread dialog (issue #684) -------
    // "See all N" opens the per-photo <dialog> full thread; the ✕, a backdrop
    // click, and Escape (native to <dialog>) close it. showModal() renders in
    // the top layer, escaping the feed card's paint containment.
    document.addEventListener('click', function (e) {
      var opener = e.target.closest('[data-open-admin-comments]');
      if (opener) {
        var d = document.getElementById(
          'admin-comments-dialog-' + opener.getAttribute('data-open-admin-comments')
        );
        if (d && !d.open && typeof d.showModal === 'function') d.showModal();
        return;
      }
      if (e.target.closest('[data-close-admin-comments]')) {
        var open = e.target.closest('dialog.admin-comments-dialog');
        if (open) open.close();
        return;
      }
      // Backdrop click (the target IS the dialog element, outside its content).
      if (
        e.target.classList &&
        e.target.classList.contains('admin-comments-dialog') &&
        e.target.tagName === 'DIALOG'
      ) {
        e.target.close();
      }
    });
  })();
</script>

<%- include('partials/footer') %>
