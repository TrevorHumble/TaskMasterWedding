<!-- src/views/how-to-play.ejs -->
<%- include('partials/head', { title: title }) %>
<%- include('partials/header') %>

  <h1 class="page-title center">How to play</h1>
  <p class="muted center">Help Lilly and Axel remember their day.</p>

  <ul class="rule-list">
    <li class="rule-row">
      <span class="rule-icon rule-icon-1" aria-hidden="true">
        <svg viewBox="0 0 24 24" width="22" height="22" style="fill:currentColor">
          <path d="M9 3l-1.7 2H4a2 2 0 0 0-2 2v11a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-3.3L15 3H9zm3 5a5 5 0 1 1 0 10 5 5 0 0 1 0-10zm0 2a3 3 0 1 0 0 6 3 3 0 0 0 0-6z"/>
        </svg>
      </span>
      <span class="rule-body">
        <span class="rule-title">Snap the tasks</span>
        <span class="rule-desc"><%= taskCount %> photo missions, worth 1 to 3 points each.</span>
      </span>
    </li>
    <li class="rule-row">
      <span class="rule-icon rule-icon-2" aria-hidden="true">
        <svg viewBox="0 0 24 24" width="22" height="22" style="fill:currentColor">
          <path d="M12 2l2.4 5.5L20 8l-4.2 4 1 6-4.8-3-4.8 3 1-6L4 8l5.6-.5L12 2zM7 20h10v2H7v-2z"/>
        </svg>
      </span>
      <span class="rule-body">
        <span class="rule-title">Earn the masters' favor</span>
        <span class="rule-desc">The Wedding Masters award bonus points for capturing great shots, funny moments, and images that give us those warm, fuzzy feelings.</span>
      </span>
    </li>
    <li class="rule-row">
      <span class="rule-icon rule-icon-3" aria-hidden="true">
        <%- include('partials/heart', { size: 20 }) %>
      </span>
      <span class="rule-body">
        <span class="rule-title">Share every memory</span>
        <span class="rule-desc">Click on Share a memory on the task board or in your profile at any time to share any photo you love, as many as you like.</span>
      </span>
    </li>
  </ul>

  <a class="btn btn-block" href="/tasks">See your list of tasks</a>

  <% if (showSkip) { %>
    <p class="back-link center"><a href="/">Skip for now</a></p>
  <% } %>

<%- include('partials/footer') %>
