<!-- src/views/admin-comments.ejs -->
<%- include('partials/head') %>
<%- include('partials/header') %>

  <h1 class="display-title">Comments</h1>

  <% if (msg) { %>
    <p class="flash"><%= msg %></p>
  <% } %>

  <p><a class="btn" href="/admin">&larr; Dashboard</a></p>

  <p class="muted">
    Hidden comments are removed from the feed immediately, but the row stays
    in the database so it can be restored.
  </p>

  <div class="comment-admin-list">
    <% comments.forEach(function (c) { %>
      <div class="comment-admin-row <%= c.taken_down ? 'is-down' : '' %>">
        <p class="comment-meta">
          <strong><%= c.guest_name || ('Guest #' + c.guest_id) %></strong>
          on <a href="/p/<%= c.submission_id %>"><%= c.task_title %></a>
        </p>
        <p class="comment-body"><%= c.body %></p>
        <% if (c.taken_down) { %>
          <p class="status-down">HIDDEN</p>
          <form action="/admin/comments/<%= c.id %>/restore" method="post">
            <button type="submit" class="btn btn-sm">Restore</button>
          </form>
        <% } else { %>
          <form action="/admin/comments/<%= c.id %>/hide" method="post"
                data-confirm="Hide this comment? It will be removed from the feed.">
            <button type="submit" class="btn btn-sm btn-danger">Hide</button>
          </form>
        <% } %>
      </div>
    <% }); %>
    <% if (comments.length === 0) { %>
      <p class="muted">No comments yet.</p>
    <% } %>
  </div>

<script src="/js/admin.js" defer></script>
<%- include('partials/footer') %>
