<!-- src/views/tasks.ejs -->
<%- include('partials/head', { title: title }) %>
<%- include('partials/header') %>

  <h1 class="page-title">Tasks</h1>

  <%# Hardcoded starter task (issue #409; DERIVED per issue #716): not a real
      tasks/submissions row — its point is derived live from whether
      guests.avatar_path is set (+1 while set, 0 while not; it never leaves a
      one-time banked award behind), so it never leaks into the public
      gallery/feed. Its completion state (starterDone) and point value
      (starterPoints) come from the single owner
      scoring.starterTaskContribution via the route (src/routes/guest.js GET
      /tasks) — this view does NOT re-derive guest.avatar_path or hardcode the
      point value. It renders as an ordinary FIRST row inside the to-do list
      (incomplete) or the done list (complete) — same <li class="task-row">
      markup as a real task — and is counted into todoCount/doneCount/
      totalCount by the route (same owner) so the chip counts next to the
      lists never disagree with what's actually inside them. %>

  <% var allDone = totalCount > 0 && todoCount === 0; %>
  <% if (allDone) { %>
    <section class="tasks-memory-cta">
      <p class="tasks-memory-cta-title">You&rsquo;ve finished every task! Have more photos, more memories to share?</p>
      <a class="btn btn-block" href="/memories/new">Share a memory</a>
    </section>
  <% } %>

  <% if (totalCount === 0) { %>
    <p class="muted">No tasks have been posted yet. Check back soon!</p>
  <% } else { %>
    <div class="task-filters">
      <a class="chip-filter<%= view === 'todo' ? ' chip-filter-active' : '' %>"
         href="/tasks">To do · <%= todoCount %></a>
      <a class="chip-filter<%= view === 'done' ? ' chip-filter-active' : '' %>"
         href="/tasks?view=done">Done · <%= doneCount %></a>
      <span class="task-progress-meta muted"><%= doneCount %> of <%= totalCount %></span>
    </div>

    <%
      // One row macro's worth of markup, twice: to-do rows carry the points
      // reward + chevron; done rows carry the guest's own photo with a check
      // badge as the completion indicator (no pills, no placeholder squares).
    %>

    <% if (view === 'done') { %>
      <% if (doneTasks.length === 0 && !starterDone) { %>
        <p class="muted">Nothing here yet &mdash; your finished tasks will show up here, photo and all.</p>
      <% } else { %>
        <ul class="task-list">
          <% if (starterDone) { %>
            <li class="task-row task-done">
              <a class="task-link" href="/me/edit">
                <span class="task-body">
                  <span class="task-title-text">Upload your profile photo</span>
                </span>
                <span class="task-points">Complete</span>
              </a>
            </li>
          <% } %>
          <% doneTasks.forEach(function (t) { %>
            <li class="task-row task-done">
              <a class="task-link" href="/tasks/<%= t.id %>">
                <span class="task-thumb-wrap">
                  <% if (t.thumb_path) { %>
                    <img src="/thumbs/<%= t.thumb_path %>" alt="" class="task-thumb" width="40" height="40" />
                  <% } %>
                  <span class="task-thumb-check" aria-label="Completed">&#10003;</span>
                </span>
                <span class="task-body">
                  <span class="task-title-text"><%= t.title %></span>
                  <span class="task-earnable-badge">
                    <%- include('partials/badge-art', { badge: t.badge }) %>
                    <span class="task-earnable-copy">Best photos earn <%= t.badge.name %> + bonus points</span>
                  </span>
                </span>
              </a>
            </li>
          <% }); %>
        </ul>
      <% } %>
    <% } else { %>
      <% if (todoTasks.length === 0 && starterDone) { %>
        <p class="muted">All done &mdash; you&rsquo;ve finished every task. The Wedding Masters are impressed.</p>
      <% } else { %>
        <%
          // The special rows (flash, today, locked) lead the to-do list —
          // above the starter profile-photo row and every ordinary task —
          // because they are the ones that expire or unlock. specialRank()
          // is the ONE owner of both "is this row special" and "where does
          // it sort" (issue #762 criterion 7; review fix, MINOR — a prior
          // version answered the first question separately, via a
          // `specialPriority` flag src/routes/guest.js emitted alongside
          // this rank function, so a future special type added to rank
          // alone, without also widening that flag, would land its row
          // silently in ordinaryTodo, un-ranked, in host sort order — nothing
          // would fail, the row would just render in the wrong place).
          // ORDINARY_RANK is the shared floor: every row ranked below it is
          // special and gets sorted; every row ranked AT it is ordinary and
          // keeps host sort order untouched. A future special type (#650's
          // lucky task) slots in by adding one more `if` here, and nothing
          // elsewhere needs to change.
          //
          // The mystery-box one-box ceiling (owner, 2026-07-20: a guest may
          // see at most one locked card at a time, ever) is applied SERVER
          // SIDE now (src/routes/guest.js's suppressedChallengeIds) — a
          // suppressed sealed challenge never reaches this template at all,
          // so priorityTodo below can never hold more than one locked row. A
          // second copy of that ceiling here would re-decide rows the server
          // already decided, and would diverge the moment a second special
          // type (#649/#650) shares the same suppression rule.
          var ORDINARY_RANK = 3;
          function specialRank(t) {
            if (t.flashActive) return 0;
            if (t.isToday) return 1;
            if (t.locked) return 2;
            return ORDINARY_RANK;
          }
          var priorityTodo = todoTasks.filter(function (t) { return specialRank(t) < ORDINARY_RANK; });
          var ordinaryTodo = todoTasks.filter(function (t) { return specialRank(t) === ORDINARY_RANK; });
          priorityTodo.sort(function (a, b) {
            return specialRank(a) - specialRank(b);
          });
        %>
        <ul class="task-list">
          <% priorityTodo.forEach(function (t) { %>
            <%- include('partials/task-todo-row', { t: t }) %>
          <% }); %>
          <% if (!starterDone) { %>
            <li class="task-row task-todo">
              <a class="task-link" href="/me/edit">
                <span class="task-body">
                  <span class="task-title-text">Upload your profile photo</span>
                  <span class="task-desc">Put a face on your profile.</span>
                </span>
                <span class="task-points">+<%= starterPoints %> pt</span>
              </a>
            </li>
          <% } %>
          <% ordinaryTodo.forEach(function (t) { %>
            <%- include('partials/task-todo-row', { t: t }) %>
          <% }); %>
        </ul>
      <% } %>
    <% } %>
  <% } %>

  <% if (!allDone) { %>
    <a class="btn btn-secondary btn-block task-share-memory" href="/memories/new">Share a memory</a>
  <% } %>

  <p class="back-link"><a href="/">&#8592; Back to my profile</a></p>

  <%# Issues #624 and #762: keeps both live clocks ticking — the locked
      challenge's "unlocks in" countdown and a flash window's remaining time.
      Deferred and self-guarding: it exits immediately only when the page has
      NEITHER a locked card nor a flash flag. Narrowing that guard back to the
      locked card alone would silently stop every flash clock and drain fill on
      a page with no mystery box. %>
  <script src="/js/task-countdown.js" defer></script>

<%- include('partials/footer') %>
