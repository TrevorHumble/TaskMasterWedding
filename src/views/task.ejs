<!-- src/views/task.ejs -->
<%- include('partials/head', { title: title }) %>
<%- include('partials/header') %>

  <% if (typeof taskComplete !== 'undefined' && taskComplete) { %>
    <!-- Success card (issue #255): the reward moment for a just-created
         completion. Supersedes the plain flash for this case — the route
         (src/routes/guest.js) writes a one-shot taskComplete payload instead
         of setFlash when result.status === 'created', so res.locals.flash is
         null here and header.ejs's flash bar does not also render. -->
    <section class="success-card" role="status">
      <svg class="success-check" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
        <path d="M4 12.5l5 5L20 6.5" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
      <h2 class="success-heading">Task complete!</h2>
      <p class="success-points">
        +1 point &mdash; you're at <%= taskComplete.points %> point<%= taskComplete.points === 1 ? '' : 's' %>
      </p>
      <p class="success-memory-prompt">Got more from tonight? <a href="/memories/new">Share a memory</a></p>
      <% if (taskComplete.newBadges.length > 0) { %>
        <ul class="success-badge-list">
          <% taskComplete.newBadges.forEach(function (b) { %>
            <li class="success-badge-item">
              <img src="<%= b.art_path %>" alt="<%= b.name %> badge" class="success-badge-art" />
              <span class="success-badge-name"><%= b.name %></span>
              <span class="success-badge-caption">A new bloom in your garden.</span>
            </li>
          <% }); %>
        </ul>
      <% } %>
    </section>
  <% } %>

  <p class="back-link"><a href="/tasks">&#8592; All tasks</a></p>
  <p class="back-link"><a href="/gallery?task=<%= task.id %>">See photos for this task</a></p>

  <h1 class="page-title center"><%= task.title %></h1>
  <div class="heart-divider" style="color:var(--color-primary);"><%- include('partials/heart', { size: 20 }) %></div>

  <% if (task.description) { %>
    <p class="task-detail-desc center"><%= task.description %></p>
  <% } %>

  <% if (submission && submission.taken_down) { %>
    <!-- Issue #190: a host takedown is sticky. Do not show the photo (not
         required by AC2) and do not present the task as not-done — that is
         what invited a silent resubmit-reverses-the-takedown loop before. -->
    <section class="existing-submission">
      <h2 class="section-title">Your photo is with the hosts</h2>
      <p class="muted">
        Your photo for this task is with the hosts right now. It'll show up again once
        they take a look — no need to resubmit, but you're welcome to replace it below.
      </p>
    </section>
  <% } else if (submission) { %>
    <section class="existing-submission">
      <h2 class="section-title">Your photo</h2>
      <img src="/uploads/<%= submission.photo_path %>"
           alt="Your submitted photo for <%= task.title %>"
           class="submission-full" />
      <% if (submission.caption) { %>
        <p class="submission-caption"><%= submission.caption %></p>
      <% } %>
      <p class="muted">This task is complete. You can replace your photo below.</p>
      <% if (!(typeof taskComplete !== 'undefined' && taskComplete)) { %>
        <%# The success card above already carries this prompt for a fresh
            'created' completion (issue #255) — only repeat it here for a
            return visit / replace, so it never prints twice on one page. %>
        <p class="muted">Got more from tonight? <a href="/memories/new">Share a memory</a></p>
      <% } %>
    </section>
  <% } %>

  <section class="upload-section">
    <h2 class="section-title"><%= submission ? 'Replace your photo' : 'Upload a photo to complete this task' %></h2>

    <form action="/tasks/<%= task.id %>/submit"
          method="POST"
          enctype="multipart/form-data">

      <div class="form-row">
        <%- include('partials/upload-field', { id: 'photo', name: 'photo', accept: 'image/*', capture: 'environment', required: true }) %>
      </div>

      <!-- Live preview target; filled by /js/upload.js -->
      <div class="preview-wrap">
        <img id="upload-preview" class="upload-preview" alt="" hidden />
      </div>

      <div class="form-row">
        <label for="caption" class="form-label">Caption (optional)</label>
        <input type="text"
               id="caption"
               name="caption"
               maxlength="500"
               placeholder="Say something about this photo"
               value="<%= submission ? submission.caption : '' %>"
               class="text-input" />
      </div>

      <p id="upload-error" class="form-error" role="alert" hidden></p>

      <button type="submit" class="btn btn-block" data-uploading-label="Uploading…">
        <%= submission ? 'Replace photo' : 'Upload & complete' %>
      </button>
    </form>
  </section>

  <!-- Direct include of the preview script (belt-and-suspenders alongside
       the footer's page-script mechanism; see section intro note). -->
  <script src="/js/upload-filename.js" defer></script>
  <script src="/js/upload.js" defer></script>

<%- include('partials/footer') %>
