<!-- src/views/task.ejs -->
<%- include('partials/head', { title: title }) %>
<%- include('partials/header') %>

  <% if (typeof taskComplete !== 'undefined' && taskComplete) { %>
    <!-- Success card (issue #255): the reward moment for a just-created
         completion. Supersedes the plain flash for this case — the route
         (src/routes/guest.js) writes a one-shot taskComplete payload instead
         of setFlash when result.status === 'created', so res.locals.flash is
         null here and header.ejs's flash bar does not also render. -->
    <%# Issue #650: the lucky treatment. `taskComplete.luckyBonus` is set by
        src/routes/guest.js ONLY when this submission banked the lucky bonus;
        it is absent on every ordinary completion, which is what keeps the
        lucky task secret until it is won. A truthy value is the bonus amount
        (1-3), so `lucky` is null for every ordinary card and the whole gold
        treatment below collapses back to the green check. %>
    <% var lucky = taskComplete.luckyBonus ? { bonus: taskComplete.luckyBonus } : null; %>
    <section class="success-card<%= lucky ? ' success-card--lucky' : '' %>" role="status">
      <% if (lucky) { %>
        <%# The lucky mark (issue #650): a gold four-leaf clover REPLACING the
            green check, so a lucky win reads as a different, rarer moment from
            the first glance rather than a footnote under an ordinary one.
            Four lobes drawn once and rotated about the centre, plus a stem. %>
        <svg class="success-clover" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
          <path d="M12 12.4C12.6 16 12.9 19 12.2 22.6" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
          <g fill="currentColor" transform="rotate(45 12 12)">
            <path d="M12 12C8.22 8.85 6.33 6.65 6.33 4.44A2.52 2.52 0 0 1 12 2.87A2.52 2.52 0 0 1 17.67 4.44C17.67 6.65 15.78 8.85 12 12Z" />
            <path d="M12 12C8.22 8.85 6.33 6.65 6.33 4.44A2.52 2.52 0 0 1 12 2.87A2.52 2.52 0 0 1 17.67 4.44C17.67 6.65 15.78 8.85 12 12Z" transform="rotate(90 12 12)" />
            <path d="M12 12C8.22 8.85 6.33 6.65 6.33 4.44A2.52 2.52 0 0 1 12 2.87A2.52 2.52 0 0 1 17.67 4.44C17.67 6.65 15.78 8.85 12 12Z" transform="rotate(180 12 12)" />
            <path d="M12 12C8.22 8.85 6.33 6.65 6.33 4.44A2.52 2.52 0 0 1 12 2.87A2.52 2.52 0 0 1 17.67 4.44C17.67 6.65 15.78 8.85 12 12Z" transform="rotate(270 12 12)" />
          </g>
        </svg>
      <% } else { %>
        <svg class="success-check" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
          <path d="M4 12.5l5 5L20 6.5" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      <% } %>
      <h2 class="success-heading"><%= lucky ? 'You found the lucky task!' : 'Task complete!' %></h2>
      <p class="success-points">
        <%# Issue #756: taskComplete.earned is what THIS submission actually
            banked (task.worth plus any admin/on-day bonus,
            src/routes/guest.js) — never task.worth alone (issue #682 AC-E),
            which would under-report a bonus submission. taskComplete.points
            is a different number: the guest's grand total after this
            submission. Both live on the same taskComplete object so this
            block can't read one without the other. %>
        <% if (lucky) { %>
          <%# The lucky win shows the split, not one merged number (owner,
              2026-07-21): the whole point is that the bonus is visible as a
              bonus. %>
          <%= taskComplete.earned - lucky.bonus %> + <strong><%= lucky.bonus %> bonus</strong>
          point<%= lucky.bonus === 1 ? '' : 's' %>! You're at <%= taskComplete.points %>!
        <% } else { %>
          +<%= taskComplete.earned %> point<%= taskComplete.earned === 1 ? '' : 's' %> &mdash; you're at <%= taskComplete.points %> point<%= taskComplete.points === 1 ? '' : 's' %>
        <% } %>
      </p>
      <p class="success-memory-prompt">Got more from tonight? <a href="/memories/new">Share a memory</a></p>
      <%- include('partials/memory-payoff') %>
    </section>
  <% } %>

  <%# Badge modal (issue #255) — the shared #badge-dialog now lives in
      partials/header.ejs (issue #644 plan step 4), included above via
      partials/header; header.ejs decides whether to auto-open it (a
      badgeMoment owed on THIS render, which may or may not be the badge
      this very submission just earned — see render-locals.js's withBadgeMoment) and
      whether to include badge-moment.js. Nothing left to render here. %>

  <p class="back-link"><a href="/tasks">&#8592; All tasks</a></p>
  <p class="back-link"><a href="/gallery?task=<%= task.id %>">See photos for this task</a></p>

  <h1 class="page-title center"><%= task.title %></h1>
  <div class="heart-divider" style="color:var(--color-primary);"><%- include('partials/heart', { size: 20 }) %></div>

  <% if (task.description) { %>
    <p class="task-detail-desc center"><%= task.description %></p>
  <% } %>

  <p class="task-detail-badge center">
    Best photos earn
    <a href="/badge/<%= taskBadge.code %>">
      <%- include('partials/badge-art', { badge: taskBadge, alt: '', imgClass: 'task-badge-icon', width: 24, height: 24 }) %>
      <%= taskBadge.name %>
    </a>
    + bonus points
  </p>

  <% if (submission && submission.taken_down) { %>
    <!-- Issue #190: a host takedown is sticky. Do not show the photo (not
         required by AC2) and do not present the task as not-done — that is
         what invited a silent resubmit-reverses-the-takedown loop before. -->
    <section class="existing-submission">
      <h2 class="section-title">Your photo is with the hosts</h2>
      <p class="muted">
        Your photo for this task is with the hosts right now. It'll show up again once
        they take a look — no need to resubmit, but you're welcome to replace it below.
      </p>
    </section>
  <% } else if (submission) { %>
    <section class="existing-submission">
      <h2 class="section-title">Your photo</h2>
      <img src="/uploads/<%= submission.photo_path %>"
           alt="Your submitted photo for <%= task.title %>"
           class="submission-full" />
      <% if (submission.caption) { %>
        <p class="submission-caption"><%= submission.caption %></p>
      <% } %>
      <p class="muted">This task is complete. You can replace your photo below.</p>
      <% if (!(typeof taskComplete !== 'undefined' && taskComplete)) { %>
        <%# The success card above already carries this prompt for a fresh
            'created' completion (issue #255) — only repeat it here for a
            return visit / replace, so it never prints twice on one page. %>
        <p class="muted">Got more from tonight? <a href="/memories/new">Share a memory</a></p>
        <%- include('partials/memory-payoff') %>
      <% } %>
    </section>
  <% } %>

  <section class="upload-section">
    <h2 class="section-title"><%= submission ? 'Replace your photo' : 'Upload a photo to complete this task' %></h2>

    <form action="/tasks/<%= task.id %>/submit"
          method="POST"
          enctype="multipart/form-data">
      <%- include('partials/csrf-field') %>

      <div class="form-row">
        <%- include('partials/upload-field', { id: 'photo', name: 'photo', accept: 'image/*', capture: 'environment', required: true }) %>
      </div>

      <!-- Live preview target; filled by /js/upload.js -->
      <div class="preview-wrap">
        <img id="upload-preview" class="upload-preview" alt="" hidden />
      </div>

      <div class="form-row">
        <label for="caption" class="form-label">Caption (optional)</label>
        <input type="text"
               id="caption"
               name="caption"
               maxlength="500"
               placeholder="Say something about this photo"
               value="<%= submission ? submission.caption : '' %>"
               class="text-input" />
      </div>

      <p id="upload-error" class="form-error" role="alert" hidden></p>

      <button type="submit" class="btn btn-block" data-uploading-label="Uploading…">
        <%= submission ? 'Replace photo' : 'Upload & complete' %>
      </button>
    </form>
  </section>

  <!-- Direct include of the preview script (belt-and-suspenders alongside
       the footer's page-script mechanism; see section intro note). -->
  <script src="/js/upload-filename.js" defer></script>
  <script src="/js/upload.js" defer></script>

<%- include('partials/footer') %>
