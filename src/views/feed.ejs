<!-- src/views/feed.ejs -->
<%- include('partials/head') %>
<%- include('partials/header') %>

  <h1 class="page-title">Feed</h1>

  <% if (photos.length === 0) { %>
    <p class="muted">No photos yet. Be the first to share one!</p>
  <% } %>

  <div class="feed">
    <% photos.forEach(function (p) { %>
      <article id="photo-<%= p.submission_id %>" class="feed-item">
        <img
          class="feed-photo"
          src="/uploads/<%= p.photo_path %>"
          alt="<%= p.task_title %>"
          loading="lazy"
        />
        <div class="feed-body">
          <p class="feed-by">
            <a href="/u/<%= p.guest_id %>"><%= p.guest_name || 'Guest' %></a>
          </p>
          <% if (p.caption) { %>
            <p class="feed-caption"><%= p.caption %></p>
          <% } %>
        </div>
        <!-- Comment and per-photo-points controls are separate follow-up
             issues; this action bar carries only the like control for now. -->
        <div class="feed-actionbar">
          <span class="like-count"><%= p.like_count %> <%= p.like_count === 1 ? 'like' : 'likes' %></span>
          <% if (guest) { %>
            <form method="post" action="/p/<%= p.submission_id %>/like" class="like-form">
              <button type="submit" class="like-button" aria-label="Like this photo">&hearts;</button>
            </form>
          <% } %>
        </div>
      </article>
    <% }); %>
  </div>

<%- include('partials/footer') %>
