<!-- src/views/public-profile.ejs -->
<%- include('partials/head') %>
<%- include('partials/header') %>

  <header class="profile-header">
    <% if (profileGuest.avatar_path) { %>
      <img class="profile-avatar"
           src="/uploads/<%= profileGuest.avatar_path %>"
           alt="<%= profileGuest.name || 'Guest' %>"
           width="96" height="96" />
    <% } else { %>
      <div class="profile-avatar-empty" aria-hidden="true">
        <%= initials(profileGuest.name) || '?' %>
      </div>
    <% } %>

    <h1 class="profile-name"><%= profileGuest.name || 'Guest' %></h1>

    <% if (score && typeof score.points === 'number') { %>
      <p class="profile-points">
        <strong><%= score.points %></strong>
        pt<%= score.points === 1 ? '' : 's' %>
      </p>
    <% } %>

    <% if (socialLinks.length > 0) { %>
      <ul class="profile-socials">
        <% socialLinks.forEach(function (s) { %>
          <li>
            <%
              var _socialClass = (s.key === 'instagram' || s.key === 'facebook' || s.key === 'website')
                ? 'social-' + s.key
                : '';
            %>
            <% if (_socialClass) { %>
              <a class="<%= _socialClass %>"
                 href="<%= s.href %>"
                 target="_blank"
                 rel="noopener noreferrer nofollow">
                <%= s.label %>
              </a>
            <% } else { %>
              <a class="pill-chip"
                 href="<%= s.href %>"
                 target="_blank"
                 rel="noopener noreferrer nofollow">
                <%= s.label %>
              </a>
            <% } %>
          </li>
        <% }); %>
      </ul>
    <% } %>
  </header>

  <section class="profile-badges">
    <h2 class="section-heading">Badges</h2>
    <% if (badges.length === 0) { %>
      <p class="muted">No badges yet.</p>
    <% } else { %>
      <ul class="badge-grid">
        <% badges.forEach(function (b) { %>
          <li class="badge-item">
            <a href="/badge/<%= b.code %>">
              <%- include('partials/badge-art', { badge: b, width: 48, height: 48 }) %>
              <span class="badge-text">
                <span class="badge-name">
                  <%= b.name %><% if (b.pointsLabel) { %> <span class="badge-points"><%= b.pointsLabel %></span><% } %>
                </span>
                <% if (b.description) { %>
                  <span class="badge-desc"><%= b.description %></span>
                <% } %>
              </span>
            </a>
          </li>
        <% }); %>
      </ul>
    <% } %>
  </section>

  <section class="profile-photos">
    <h2 class="section-heading">Photos</h2>
    <%# Crowd-favorite rank lookup (issue #788): submission_id -> rank (1 is
        gold), supplied by the route from ONE scoring.crowdFavorites() call.
        Defaults to an empty lookup when a caller renders this view without
        it, so the crown mark below simply matches nothing rather than
        throwing. %>
    <% var crownRank = (typeof crownRank !== 'undefined' && crownRank) ? crownRank : {}; %>
    <% if (photos.length === 0) { %>
      <p class="muted">No photos shared yet.</p>
    <% } else { %>
      <div class="gallery-grid" id="galleryGrid">
        <% photos.forEach(function (p) { %>
          <figure class="gallery-item">
            <a
              class="gallery-thumb-btn"
              href="/p/<%= p.submission_id %>"
              aria-label="View photo for <%= p.task_title || 'a shared memory' %>"
            >
              <img
                class="gallery-thumb"
                src="/thumbs/<%= p.thumb_path %>"
                alt="<%= p.task_title || 'a shared memory' %>"
                loading="lazy"
                width="400"
                height="400"
              />
              <% if (crownRank[p.submission_id]) { %>
                <%- include('partials/crowd-favorite-mark', { rank: crownRank[p.submission_id] }) %>
              <% } %>
            </a>
            <figcaption class="gallery-caption">
              <span class="gallery-task"><%= p.task_title || 'a shared memory' %></span>
              <% if (p.caption) { %>
                <span class="gallery-text"><%= p.caption %></span>
              <% } %>
            </figcaption>
          </figure>
        <% }); %>
      </div>
    <% } %>
  </section>

<%- include('partials/footer') %>
